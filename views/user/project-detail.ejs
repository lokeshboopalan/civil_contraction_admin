<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">${project.title}</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/projects">Projects</a></li>
                <li class="breadcrumb-item text-secondary active">${project.title}</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- Project Detail Start -->
    <div class="container-fluid project-detail py-5">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-8">
                    ${(() => {
                        if (project.images && project.images[0]) {
                            return `
                                <div class="row g-3 mb-4">
                                    <div class="col-12">
                                        <img src="${project.images[0].url}" class="img-fluid w-100 rounded" alt="${project.title}" style="height: 450px; object-fit: cover;">
                                    </div>
                                    ${project.images.slice(1, 4).map(image => `
                                        <div class="col-md-4">
                                            <img src="${image.url}" class="img-fluid w-100 rounded" alt="${project.title}" style="height: 150px; object-fit: cover;">
                                        </div>
                                    `).join('')}
                                </div>
                            `;
                        } else {
                            return `
                                <img src="/frontend/img/project-detail.jpg" class="img-fluid w-100 rounded mb-4" alt="${project.title}" style="height: 450px; object-fit: cover;">
                            `;
                        }
                    })()}

                    <h2 class="mb-3">${project.title}</h2>
                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <span class="badge bg-primary p-2">${project.status}</span>
                        <span class="text-muted"><i class="fas fa-calendar-alt me-2"></i>Start: ${new Date(project.startDate).toLocaleDateString()}</span>
                        ${project.endDate ? `<span class="text-muted"><i class="fas fa-calendar-check me-2"></i>End: ${new Date(project.endDate).toLocaleDateString()}</span>` : ''}
                    </div>
                    <p class="mb-4">${project.description || 'Quality construction project delivered with excellence and commitment to client satisfaction.'}</p>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h4 class="mb-3">Project Details</h4>
                            <ul class="list-unstyled">
                                <li class="mb-2"><strong><i class="fas fa-map-marker-alt text-secondary me-2"></i>Location:</strong> ${project.location}</li>
                                <li class="mb-2"><strong><i class="fas fa-tag text-secondary me-2"></i>Status:</strong> <span class="badge bg-primary">${project.status}</span></li>
                                <li class="mb-2"><strong><i class="fas fa-calendar-alt text-secondary me-2"></i>Start Date:</strong> ${new Date(project.startDate).toLocaleDateString()}</li>
                                ${project.endDate ? `<li class="mb-2"><strong><i class="fas fa-calendar-check text-secondary me-2"></i>End Date:</strong> ${new Date(project.endDate).toLocaleDateString()}</li>` : ''}
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h4 class="mb-3">Key Features</h4>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="fas fa-check-circle text-secondary me-2"></i> Quality Construction</li>
                                <li class="mb-2"><i class="fas fa-check-circle text-secondary me-2"></i> Modern Design</li>
                                <li class="mb-2"><i class="fas fa-check-circle text-secondary me-2"></i> Premium Materials</li>
                                <li class="mb-2"><i class="fas fa-check-circle text-secondary me-2"></i> Timely Delivery</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="bg-light p-4 rounded">
                        <h4 class="mb-4">Project Information</h4>
                        <div class="mb-3">
                            <i class="fas fa-building text-secondary me-2"></i>
                            <strong>Project Type:</strong> Construction
                        </div>
                        <div class="mb-3">
                            <i class="fas fa-users text-secondary me-2"></i>
                            <strong>Client:</strong> Private Client
                        </div>
                        <div class="mb-3">
                            <i class="fas fa-clock text-secondary me-2"></i>
                            <strong>Duration:</strong> ${project.endDate ? `${Math.ceil((new Date(project.endDate) - new Date(project.startDate)) / (1000 * 60 * 60 * 24))} days` : 'Ongoing'}
                        </div>
                        <hr>
                        <a href="/contact" class="btn btn-secondary w-100 py-3">Request Similar Project</a>
                    </div>

                    <!-- Gallery Images -->
                    ${(() => {
                        if (project.images && project.images.length > 1) {
                            return `
                                <div class="bg-light p-4 rounded mt-4">
                                    <h4 class="mb-3">Project Gallery</h4>
                                    <div class="row g-2">
                                        ${project.images.map(image => `
                                            <div class="col-4">
                                                <img src="${image.url}" class="img-fluid rounded" alt="Gallery" style="height: 80px; width: 100%; object-fit: cover;">
                                            </div>
                                        `).join('')}
                                    </div>
                                </div>
                            `;
                        } else {
                            return '';
                        }
                    })()}
                </div>
            </div>
        </div>
    </div>
    <!-- Project Detail End -->
` }) %>