<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">Our News & Blog</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item text-secondary active">Blog</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- Blog Start -->
    <div class="container-fluid blog py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">News & Blog</p>
                <h2 class="display-4 text-capitalize mb-3">Our latest news post and articles</h2>
            </div>
            <div class="row g-4">
                ${(() => {
                    if (articles && articles.length > 0) {
                        return articles.map((article, index) => `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                                <div class="blog-item h-100">
                                    <div class="blog-img">
                                        ${article.images && article.images[0] ? `
                                            <img src="${article.images[0].url}" class="img-fluid w-100" alt="${article.title}" style="height: 250px; object-fit: cover;">
                                        ` : `
                                            <img src="/frontend/img/blog-${(index % 3) + 1}.jpg" class="img-fluid w-100" alt="Blog" style="height: 250px; object-fit: cover;">
                                        `}
                                    </div>
                                    <div class="blog-content p-4">
                                        <div class="d-flex justify-content-between mb-3">
                                            <p class="mb-0"><i class="fa fa-calendar-check text-secondary me-1"></i> ${new Date(article.createdAt).toLocaleDateString()}</p>
                                            <p class="mb-0"><i class="fa fa-user text-secondary me-1"></i> ${article.author || 'Admin'}</p>
                                        </div>
                                        <a href="/articles/${article.id}" class="h4 d-block mb-4">${article.title}</a>
                                        <p class="mb-3">${article.shortDescription || (article.description ? article.description.substring(0, 120) : 'Read our latest insights and updates about the construction industry.')}</p>
                                        <a class="btn btn-secondary py-2 px-4" href="/articles/${article.id}">Read More</a>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        return `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                                <div class="blog-item h-100">
                                    <div class="blog-img">
                                        <img src="/frontend/img/blog-1.jpg" class="img-fluid w-100" alt="Blog" style="height: 250px; object-fit: cover;">
                                    </div>
                                    <div class="blog-content p-4">
                                        <div class="d-flex justify-content-between mb-3">
                                            <p class="mb-0"><i class="fa fa-calendar-check text-secondary me-1"></i> 26 March 2025</p>
                                            <p class="mb-0"><i class="fa fa-user text-secondary me-1"></i> Admin</p>
                                        </div>
                                        <a href="#" class="h4 d-block mb-4">Emerging Construction Tech Trends in 2025</a>
                                        <p class="mb-3">Discover the latest technological advancements shaping the construction industry this year.</p>
                                        <a class="btn btn-secondary py-2 px-4" href="#">Read More</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                                <div class="blog-item h-100">
                                    <div class="blog-img">
                                        <img src="/frontend/img/blog-2.jpg" class="img-fluid w-100" alt="Blog" style="height: 250px; object-fit: cover;">
                                    </div>
                                    <div class="blog-content p-4">
                                        <div class="d-flex justify-content-between mb-3">
                                            <p class="mb-0"><i class="fa fa-calendar-check text-secondary me-1"></i> 15 March 2025</p>
                                            <p class="mb-0"><i class="fa fa-user text-secondary me-1"></i> Admin</p>
                                        </div>
                                        <a href="#" class="h4 d-block mb-4">Sustainable Building Practices for Modern Construction</a>
                                        <p class="mb-3">Learn about eco-friendly construction methods and sustainable materials.</p>
                                        <a class="btn btn-secondary py-2 px-4" href="#">Read More</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                                <div class="blog-item h-100">
                                    <div class="blog-img">
                                        <img src="/frontend/img/blog-3.jpg" class="img-fluid w-100" alt="Blog" style="height: 250px; object-fit: cover;">
                                    </div>
                                    <div class="blog-content p-4">
                                        <div class="d-flex justify-content-between mb-3">
                                            <p class="mb-0"><i class="fa fa-calendar-check text-secondary me-1"></i> 5 March 2025</p>
                                            <p class="mb-0"><i class="fa fa-user text-secondary me-1"></i> Admin</p>
                                        </div>
                                        <a href="#" class="h4 d-block mb-4">Safety Standards in Construction: What You Need to Know</a>
                                        <p class="mb-3">Essential safety protocols and standards for construction sites.</p>
                                        <a class="btn btn-secondary py-2 px-4" href="#">Read More</a>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                })()}
                <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.2s">
                    <a class="btn btn-secondary py-3 px-5 mt-4" href="/articles">Load More Articles</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Blog End -->
` }) %>