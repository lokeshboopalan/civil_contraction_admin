<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">Our Services</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item text-secondary active">Services</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- Services Start -->
    <div class="container-fluid services-modern py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">What We Offer</p>
                <h2 class="display-4 text-capitalize mb-3">Our Premium Services</h2>
                <p class="mb-0">We provide comprehensive construction services tailored to meet your specific needs with excellence and innovation.</p>
            </div>
            <div class="row g-4">
                ${(() => {
                    if (services && services.length > 0) {
                        return services.map((service, index) => `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                                <div class="service-card-modern bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="service-card-img position-relative overflow-hidden">
                                        ${service.images && service.images[0] ? `
                                            <img src="${service.images[0].url}" class="img-fluid w-100" alt="${service.title}" style="height: 220px; width: 100%; object-fit: cover;">
                                        ` : `
                                            <img src="/frontend/img/service-${(index % 6) + 1}.jpg" class="img-fluid w-100" alt="Service" style="height: 220px; width: 100%; object-fit: cover;">
                                        `}
                                        <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                            <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                <i class="fas ${service.icon || 'fa-home'} text-white fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="service-card-content p-4">
                                        <h4 class="mb-3">${service.title}</h4>
                                        <p class="text-muted mb-4">${service.shortDescription || service.description ? (service.description || service.shortDescription).substring(0, 100) + '...' : 'Quality service delivered with excellence and commitment to client satisfaction.'}</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <a href="/services/${service.id}" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                            <div class="service-features d-flex gap-2">
                                                ${service.features && service.features.length > 0 ? `
                                                    <small class="text-muted"><i class="fas fa-check-circle text-primary me-1"></i> ${service.features.length}+ Features</small>
                                                ` : ''}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        return `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                                <div class="service-card-modern bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="service-card-img position-relative overflow-hidden">
                                        <img src="/frontend/img/service-1.jpg" class="img-fluid w-100" alt="General Construction" style="height: 220px; width: 100%; object-fit: cover;">
                                        <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                            <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                <i class="fas fa-home text-white fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="service-card-content p-4">
                                        <h4 class="mb-3">General Construction</h4>
                                        <p class="text-muted mb-4">Expert general construction services for residential and commercial projects with quality assurance and timely delivery.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <a href="#" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                            <div class="service-features">
                                                <small class="text-muted"><i class="fas fa-check-circle text-primary me-1"></i> Premium Quality</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                                <div class="service-card-modern bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="service-card-img position-relative overflow-hidden">
                                        <img src="/frontend/img/service-2.jpg" class="img-fluid w-100" alt="Property Maintenance" style="height: 220px; width: 100%; object-fit: cover;">
                                        <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                            <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                <i class="fas fa-tools text-white fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="service-card-content p-4">
                                        <h4 class="mb-3">Property Maintenance</h4>
                                        <p class="text-muted mb-4">Complete property maintenance services to keep your buildings in perfect condition with regular inspections.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <a href="#" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                            <div class="service-features">
                                                <small class="text-muted"><i class="fas fa-check-circle text-primary me-1"></i> 24/7 Support</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                                <div class="service-card-modern bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="service-card-img position-relative overflow-hidden">
                                        <img src="/frontend/img/service-3.jpg" class="img-fluid w-100" alt="Project Management" style="height: 220px; width: 100%; object-fit: cover;">
                                        <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                            <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                <i class="fas fa-chart-line text-white fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="service-card-content p-4">
                                        <h4 class="mb-3">Project Management</h4>
                                        <p class="text-muted mb-4">Professional project management services ensuring timely delivery and quality control throughout the project lifecycle.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <a href="#" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                            <div class="service-features">
                                                <small class="text-muted"><i class="fas fa-check-circle text-primary me-1"></i> Expert Team</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                })()}
                <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.2s">
                    <a class="btn btn-primary py-3 px-5 mt-4 rounded-pill" href="/services">View All Services <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>
        </div>
    </div>
    <!-- Services End -->
` }) %>