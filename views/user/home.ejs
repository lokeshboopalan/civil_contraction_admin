<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: ` <!-- Spinner Start -->
    <div id="spinner"
        class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Topbar Start -->
    <div class="container-fluid topbar d-none d-xl-block w-100">
        <div class="row gx-0 align-items-center" style="height: 45px;">
            <div class="col-lg-6 text-center text-lg-start mb-lg-0">
                <div class="d-flex flex-wrap">
                    <a href="#" class="text-muted me-4"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Find A
                        Location</a>
                    <a href="#" class="text-muted me-4"><i
                            class="fas fa-phone-alt text-secondary me-2"></i>+01234567890</a>
                    <a href="#" class="text-muted me-0"><i
                            class="fas fa-envelope text-secondary me-2"></i>Example@gmail.com</a>
                </div>
            </div>
            <div class="col-lg-6 text-center text-lg-end">
                <div class="d-flex align-items-center justify-content-end">
                    <a href="#" class="text-muted me-3"><i class="fas fa-clock text-secondary me-2"></i>Mon - Sat 8:00 -
                        17:30, Sunday - CLOSED</a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-facebook-f"></i></a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-twitter"></i></a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-instagram"></i></a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>
    </div>
    <!-- Topbar End -->

    <!-- Navbar & Hero Start -->
    <div class="container-fluid sticky-top px-0">
        <nav class="navbar navbar-expand-lg navbar-dark bg-light py-3 px-4">
            <a href="/" class="navbar-brand p-0">
                <h1 class="text-secondary display-6"><i class="fas fa-city text-primary me-3"></i>Thirupathi</h1>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="fa fa-bars"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <div class="navbar-nav ms-auto pt-2 pt-lg-0">
                    <a href="/" class="nav-item nav-link ${currentPage === 'home' ? 'active' : ''}">Home</a>
                    <a href="/about" class="nav-item nav-link ${currentPage === 'about' ? 'active' : ''}">About</a>
                    <a href="/services"
                        class="nav-item nav-link ${currentPage === 'services' ? 'active' : ''}">Services</a>
                    <a href="/projects"
                        class="nav-item nav-link ${currentPage === 'projects' ? 'active' : ''}">Projects</a>
                    <a href="/articles" class="nav-item nav-link ${currentPage === 'articles' ? 'active' : ''}">Blog</a>
                    <a href="/contact"
                        class="nav-item nav-link ${currentPage === 'contact' ? 'active' : ''}">Contact</a>
                </div>
            </div>
        </nav>
    </div>
    <!-- Navbar & Hero End -->

    <!-- Carousel Start -->
    <div class="container-fluid overflow-hidden px-0">
        <div id="carouselId" class="carousel slide" data-bs-ride="carousel">
            <ol class="carousel-indicators">
                ${sliders && sliders.length > 0 ? sliders.map((slider, index) => `
                <li data-bs-target="#carouselId" data-bs-slide-to="${index}" class="${index === 0 ? 'active' : ''}">
                </li>
                `).join('') : `
                <li data-bs-target="#carouselId" data-bs-slide-to="0" class="active"></li>
                <li data-bs-target="#carouselId" data-bs-slide-to="1"></li>
                <li data-bs-target="#carouselId" data-bs-slide-to="2"></li>
                `}
            </ol>
            <div class="carousel-inner" role="listbox">
                ${(() => {
                if (sliders && sliders.length > 0) {
                return sliders.map((slider, index) => `
                <div class="carousel-item ${index === 0 ? 'active' : ''}">
                    ${slider.images && slider.images[0] ? `
                    <img src="${slider.images[0].url}" class="img-fluid w-100" alt="${slider.title}">
                    ` : `
                    <div style="height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
                    `}
                    <div class="carousel-caption">
                        <p class="text-uppercase text-secondary fs-4 mb-0">${slider.subTitle || 'Construction Business'}
                        </p>
                        <h1 class="display-1 text-capitalize text-white mb-4">${slider.title}</h1>
                        <p class="mb-5 fs-5">${slider.description || 'Quality construction services with commitment to
                            excellence.'}</p>
                        <div class="d-flex justify-content-center">
                            <a class="btn btn-primary d-flex py-3 px-5 me-2" href="/about">Apply Now</a>
                            <a class="btn btn-secondary d-inline-block py-3 px-5 ms-2" href="/services">Read More</a>
                        </div>
                    </div>
                </div>
                `).join('');
                } else {
                return `
                <div class="carousel-item active">
                    <img src="/frontend/img/carousel-1.jpg" class="img-fluid w-100" alt="First slide">
                    <div class="carousel-caption">
                        <p class="text-uppercase text-secondary fs-4 mb-0">Construction Business</p>
                        <h1 class="display-1 text-capitalize text-white mb-4">We build something new and consistent.
                        </h1>
                        <p class="mb-5 fs-5">Quality construction services with commitment to excellence.</p>
                        <div class="d-flex justify-content-center">
                            <a class="btn btn-primary d-flex py-3 px-5 me-2" href="/about">Apply Now</a>
                            <a class="btn btn-secondary d-inline-block py-3 px-5 ms-2" href="/services">Read More</a>
                        </div>
                    </div>
                </div>
                `;
                }
                })()}
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselId" data-bs-slide="prev">
                <span class="carousel-control-prev-icon btn-lg-square" aria-hidden="true"><i
                        class="fas fa-chevron-left fa-2x"></i></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselId" data-bs-slide="next">
                <span class="carousel-control-next-icon btn-lg-square" aria-hidden="true"><i
                        class="fas fa-chevron-right fa-2x"></i></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
    <!-- Carousel End -->

    <!-- About Start -->
    <div class="container-fluid about py-5">
        <div class="container py-5">
            <div class="row g-5 align-items-center">
                <div class="col-xl-6 wow fadeInLeft" data-wow-delay="0.1s">
                    <div class="about-item-image d-flex">
                        ${about.images && about.images[0] ? `
                        <img src="${about.images[0].url}" class="img-1 img-fluid w-50" alt="${about.title}">
                        ` : `
                        <img src="/frontend/img/about.jpg" class="img-1 img-fluid w-50" alt="About">
                        `}
                        ${about.images && about.images[1] ? `
                        <img src="${about.images[1].url}" class="img-2 img-fluid w-50" alt="${about.title}">
                        ` : `
                        <img src="/frontend/img/about-3.jpg" class="img-2 img-fluid w-50" alt="About">
                        `}
                        <div class="about-item-image-content">
                            <img src="/frontend/img/about-1.png" class="img-fluid w-100 h-100"
                                style="object-fit: cover;" alt="">
                        </div>
                    </div>
                </div>
                <div class="col-xl-6 wow fadeInRight" data-wow-delay="0.1s">
                    <div class="about-item-content">
                        <p class="text-uppercase text-secondary fs-5 mb-0">${about.subtitle || 'WE ARE CONSTRUCTION
                            COMPANY'}</p>
                        <h2 class="display-4 text-capitalize mb-3">${about.title || 'Making your vision come true at the
                            basics.'}</h2>
                        <p class="mb-4 fs-5">${about.shortDescription || 'Quality construction services with commitment
                            to excellence.'}</p>
                        <div class="pb-4 mb-4 border-bottom">
                            <div class="row g-4">
                                <div class="col-lg-4">
                                    <div class="about-item-content-img">
                                        <img src="/frontend/img/about-2.jpg" class="img-fluid w-100" alt="">
                                    </div>
                                </div>
                                <div class="col-lg-8">
                                    <div class="d-flex mb-4">
                                        <div class="text-secondary">
                                            <i class="fas fa-user-shield fa-3x"></i>
                                        </div>
                                        <h4 class="ms-3">Building quality standards</h4>
                                    </div>
                                    <div class="d-flex">
                                        <div class="text-secondary">
                                            <i class="fas fa-users-cog fa-3x"></i>
                                        </div>
                                        <h4 class="ms-3">Certified engineer's team</h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row gy-0 gx-4 justify-content-between pb-4">
                            <div class="col-lg-6">
                                <p class="text-dark"><i class="fas fa-check text-secondary me-1"></i> 100% Satisfaction
                                </p>
                                <p class="text-dark"><i class="fas fa-check text-secondary me-1"></i> Trained Employees
                                </p>
                            </div>
                            <div class="col-lg-6">
                                <p class="text-dark"><i class="fas fa-check text-secondary me-1"></i> Annual Pass
                                    Programs</p>
                                <p class="text-dark mb-0"><i class="fas fa-check text-secondary me-1"></i> Flexible and
                                    cost effective</p>
                            </div>
                        </div>
                        <a class="btn btn-secondary d-inline-block py-3 px-5 me-2 flex-shrink-0 wow fadeInUp"
                            data-wow-delay="0.1s" href="/about">Discover More</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- About End -->

    <!-- Features Start -->
    <div class="container-fluid feature bg-light py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">Why US</p>
                <h2 class="display-4 text-capitalize mb-3">Why Choose Us</h2>
            </div>
            <div class="row g-4">
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-city text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Expert Engineer</a>
                        <p class="mb-0">Professional and experienced engineers dedicated to quality.</p>
                    </div>
                </div>
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.4s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-funnel-dollar text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Free Estimates</a>
                        <p class="mb-0">Get free project estimates and consultation.</p>
                    </div>
                </div>
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.6s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-tools text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Quality Materials</a>
                        <p class="mb-0">We use only the highest quality materials for all projects.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Features End -->

    <!-- Services Start -->
    <div class="container-fluid service py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">Our Services</p>
                <h2 class="display-4 text-capitalize mb-3">Our service is creative & decent</h2>
            </div>
            <div class="row g-4">
                ${services && services.length > 0 ? services.slice(0, 6).map((service, index) => `
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                    <div class="service-item">
                        <div class="service-img position-relative overflow-hidden">
                            ${service.images && service.images[0] ? `
                            <img src="${service.images[0].url}" class="img-fluid w-100" alt="${service.title}"
                                style="height: 250px; width: 100%; object-fit: cover;">
                            ` : `
                            <img src="/frontend/img/service-${(index % 6) + 1}.jpg" class="img-fluid w-100"
                                alt="Service" style="height: 250px; width: 100%; object-fit: cover;">
                            `}
                        </div>
                        <div class="service-content text-center p-4">
                            <div class="bg-secondary btn-xl-square mx-auto" style="width: 80px; height: 80px;">
                                <i class="fas ${service.icon || 'fa-home'} text-primary fa-3x"></i>
                            </div>
                            <a href="/services/${service.id}" class="d-block fs-5 my-3 text-white">${service.title}</a>
                            <p class="text-white-50 mb-3 small">${service.shortDescription ?
                                service.shortDescription.substring(0, 100) : 'Quality service delivered with
                                excellence.'}</p>
                            <a class="btn btn-secondary py-2 px-4" href="/services/${service.id}">Read More</a>
                        </div>
                        <div class="service-title">
                            <div class="d-flex align-items-center justify-content-between ps-4 w-100">
                                <h4 class="mb-0" style="font-size: 1rem;">${service.title}</h4>
                                <div class="btn-xl-square bg-secondary p-2" style="width: 50px; height: 50px;">
                                    <i class="fas ${service.icon || 'fa-home'} text-primary fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                `).join('') : `
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="service-item">
                        <div class="service-img position-relative overflow-hidden">
                            <img src="/frontend/img/service-1.jpg" class="img-fluid w-100" alt="General Construction"
                                style="height: 250px; width: 100%; object-fit: cover;">
                        </div>
                        <div class="service-content text-center p-4">
                            <div class="bg-secondary btn-xl-square mx-auto" style="width: 80px; height: 80px;">
                                <i class="fas fa-home text-primary fa-3x"></i>
                            </div>
                            <a href="#" class="d-block fs-5 my-3 text-white">General Construction</a>
                            <p class="text-white-50 mb-3 small">Expert general construction services for residential and
                                commercial projects.</p>
                            <a class="btn btn-secondary py-2 px-4" href="#">Read More</a>
                        </div>
                        <div class="service-title">
                            <div class="d-flex align-items-center justify-content-between ps-4 w-100">
                                <h4 class="mb-0" style="font-size: 1rem;">General Construction</h4>
                                <div class="btn-xl-square bg-secondary p-2" style="width: 50px; height: 50px;">
                                    <i class="fas fa-home text-primary fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="service-item">
                        <div class="service-img position-relative overflow-hidden">
                            <img src="/frontend/img/service-2.jpg" class="img-fluid w-100" alt="Property Maintenance"
                                style="height: 250px; width: 100%; object-fit: cover;">
                        </div>
                        <div class="service-content text-center p-4">
                            <div class="bg-secondary btn-xl-square mx-auto" style="width: 80px; height: 80px;">
                                <i class="fas fa-tools text-primary fa-3x"></i>
                            </div>
                            <a href="#" class="d-block fs-5 my-3 text-white">Property Maintenance</a>
                            <p class="text-white-50 mb-3 small">Complete property maintenance services to keep your
                                buildings perfect.</p>
                            <a class="btn btn-secondary py-2 px-4" href="#">Read More</a>
                        </div>
                        <div class="service-title">
                            <div class="d-flex align-items-center justify-content-between ps-4 w-100">
                                <h4 class="mb-0" style="font-size: 1rem;">Property Maintenance</h4>
                                <div class="btn-xl-square bg-secondary p-2" style="width: 50px; height: 50px;">
                                    <i class="fas fa-tools text-primary fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                    <div class="service-item">
                        <div class="service-img position-relative overflow-hidden">
                            <img src="/frontend/img/service-3.jpg" class="img-fluid w-100" alt="Project Management"
                                style="height: 250px; width: 100%; object-fit: cover;">
                        </div>
                        <div class="service-content text-center p-4">
                            <div class="bg-secondary btn-xl-square mx-auto" style="width: 80px; height: 80px;">
                                <i class="fas fa-chart-line text-primary fa-3x"></i>
                            </div>
                            <a href="#" class="d-block fs-5 my-3 text-white">Project Management</a>
                            <p class="text-white-50 mb-3 small">Professional project management ensuring timely delivery
                                and quality.</p>
                            <a class="btn btn-secondary py-2 px-4" href="#">Read More</a>
                        </div>
                        <div class="service-title">
                            <div class="d-flex align-items-center justify-content-between ps-4 w-100">
                                <h4 class="mb-0" style="font-size: 1rem;">Project Management</h4>
                                <div class="btn-xl-square bg-secondary p-2" style="width: 50px; height: 50px;">
                                    <i class="fas fa-chart-line text-primary fa-2x"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                `}
                <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.2s">
                    <a class="btn btn-secondary py-3 px-5 mt-4" href="/services">More Services</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Services End -->

    <!-- Blog Start -->
    <div class="container-fluid blog bg-light py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">News & Blog</p>
                <h2 class="display-4 text-capitalize mb-3">Our latest news post and articles</h2>
            </div>
            <div class="row g-4">
                ${latestArticles && latestArticles.length > 0 ? latestArticles.map(article => `
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="blog-item h-100">
                        <div class="blog-img">
                            ${article.images && article.images[0] ? `
                            <img src="${article.images[0].url}" class="img-fluid w-100" alt="${article.title}"
                                style="height: 250px; object-fit: cover;">
                            ` : `
                            <img src="/frontend/img/blog-1.jpg" class="img-fluid w-100" alt="Blog"
                                style="height: 250px; object-fit: cover;">
                            `}
                        </div>
                        <div class="blog-content p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <p class="mb-0"><i class="fa fa-calendar-check text-secondary me-1"></i> ${new
                                    Date(article.createdAt).toLocaleDateString()}</p>
                                <p class="mb-0"><i class="fa fa-user text-secondary me-1"></i> Admin</p>
                            </div>
                            <a href="/articles/${article.id}" class="h4 d-block mb-4">${article.title}</a>
                            <a class="btn btn-secondary py-2 px-4" href="/articles/${article.id}">Read More</a>
                        </div>
                    </div>
                </div>
                `).join('') : `
                <div class="col-12 text-center">
                    <p>No articles available at the moment.</p>
                </div>
                `}
            </div>
        </div>
    </div>
    <!-- Blog End -->
    ` }) %>