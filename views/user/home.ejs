<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Hero Carousel Start -->
    <div class="container-fluid overflow-hidden px-0">
        <div id="carouselId" class="carousel slide" data-bs-ride="carousel">
            <ol class="carousel-indicators">
                ${(() => {
                    if (sliders && sliders.length > 0) {
                        return sliders.map((slider, index) => `
                            <li data-bs-target="#carouselId" data-bs-slide-to="${index}" class="${index === 0 ? 'active' : ''}"></li>
                        `).join('');
                    } else {
                        return `
                            <li data-bs-target="#carouselId" data-bs-slide-to="0" class="active"></li>
                            <li data-bs-target="#carouselId" data-bs-slide-to="1"></li>
                            <li data-bs-target="#carouselId" data-bs-slide-to="2"></li>
                        `;
                    }
                })()}
            </ol>
            <div class="carousel-inner" role="listbox">
                ${(() => {
                    if (sliders && sliders.length > 0) {
                        return sliders.map((slider, index) => `
                            <div class="carousel-item ${index === 0 ? 'active' : ''}">
                                ${slider.images && slider.images[0] ? `
                                    <img src="${slider.images[0].url}" class="img-fluid w-100" alt="${slider.title}" style="height: 100vh; width: 100%; object-fit: cover;">
                                ` : `
                                    <img src="/frontend/img/carousel-${index + 1}.jpg" class="img-fluid w-100" alt="Slide" style="height: 100vh; width: 100%; object-fit: cover;">
                                `}
                                <div class="carousel-caption">
                                    <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">${slider.subTitle || 'Construction Business'}</span>
                                    <h1 class="display-1 fw-bold text-white mb-4">${slider.title}</h1>
                                    <p class="fs-5 text-white mb-5 opacity-75">${slider.description || 'Quality construction services with commitment to excellence.'}</p>
                                    <div class="d-flex justify-content-center gap-3">
                                        <a class="btn btn-primary rounded-pill px-5 py-3" href="/about">Apply Now <i class="fas fa-arrow-right ms-2"></i></a>
                                        <a class="btn btn-outline-light rounded-pill px-5 py-3" href="/services">Read More</a>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        return `
                            <div class="carousel-item active">
                                <img src="/frontend/img/carousel-1.jpg" class="img-fluid w-100" alt="First slide" style="height: 100vh; width: 100%; object-fit: cover;">
                                <div class="carousel-caption">
                                    <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">Construction Business</span>
                                    <h1 class="display-1 fw-bold text-white mb-4">We Build Something New and Consistent</h1>
                                    <p class="fs-5 text-white mb-5 opacity-75">Quality construction services with commitment to excellence.</p>
                                    <div class="d-flex justify-content-center gap-3">
                                        <a class="btn btn-primary rounded-pill px-5 py-3" href="/about">Apply Now <i class="fas fa-arrow-right ms-2"></i></a>
                                        <a class="btn btn-outline-light rounded-pill px-5 py-3" href="/services">Read More</a>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                })()}
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselId" data-bs-slide="prev">
                <span class="carousel-control-prev-icon btn-lg-square" aria-hidden="true"><i class="fas fa-chevron-left fa-2x"></i></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselId" data-bs-slide="next">
                <span class="carousel-control-next-icon btn-lg-square" aria-hidden="true"><i class="fas fa-chevron-right fa-2x"></i></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
    <!-- Hero Carousel End -->

    <!-- About Section Start -->
    <div class="container-fluid about-modern py-5">
        <div class="container py-5">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6 wow fadeInLeft" data-wow-delay="0.1s">
                    <div class="about-image-wrapper position-relative">
                        <div class="about-image-main position-relative">
                            ${about.images && about.images[0] ? `
                                <img src="${about.images[0].url}" class="img-fluid rounded-4 shadow-lg w-100" alt="${about.title}" style="height: 450px; object-fit: cover;">
                            ` : `
                                <img src="/frontend/img/about-main.jpg" class="img-fluid rounded-4 shadow-lg w-100" alt="About" style="height: 450px; object-fit: cover;">
                            `}
                            <div class="about-experience-badge position-absolute bg-primary text-white rounded-4 p-4 shadow-lg">
                                <h2 class="display-4 fw-bold mb-0">${about.yearsOfExperience || '15'}</h2>
                                <p class="mb-0">Years of<br>Experience</p>
                            </div>
                        </div>
                        <div class="about-image-secondary position-absolute">
                            ${about.images && about.images[1] ? `
                                <img src="${about.images[1].url}" class="img-fluid rounded-4 shadow-lg" alt="${about.title}" style="width: 160px; height: 160px; object-fit: cover;">
                            ` : `
                                <img src="/frontend/img/about-secondary.jpg" class="img-fluid rounded-4 shadow-lg" alt="About" style="width: 160px; height: 160px; object-fit: cover;">
                            `}
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 wow fadeInRight" data-wow-delay="0.1s">
                    <div class="about-content">
                        <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">About Company</span>
                        <h2 class="display-4 fw-bold mb-3">${about.title || 'Building Excellence Since 2010'}</h2>
                        <p class="lead text-secondary mb-4">${about.subtitle || 'We create exceptional spaces that inspire and endure.'}</p>
                        <p class="text-muted mb-4">${about.shortDescription || 'Thirupathi Constructions is a premier construction company dedicated to delivering quality projects with integrity, innovation, and excellence.'}</p>
                        <div class="row g-4 mb-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0 bg-primary rounded-circle p-3 me-3">
                                        <i class="fas fa-check-circle text-white fa-2x"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1">Quality Assurance</h5>
                                        <p class="text-muted mb-0">Highest quality standards</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0 bg-primary rounded-circle p-3 me-3">
                                        <i class="fas fa-clock text-white fa-2x"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1">Timely Delivery</h5>
                                        <p class="text-muted mb-0">On-time project completion</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <a href="/about" class="btn btn-primary rounded-pill px-5 py-3 me-2">Discover More <i class="fas fa-arrow-right ms-2"></i></a>
                        <a href="/contact" class="btn btn-outline-primary rounded-pill px-5 py-3">Contact Us</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- About Section End -->

    <!-- Services Section Start -->
<div class="container-fluid services-modern py-5 bg-light">
    <div class="container py-5">
        <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
            <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">What We Offer</span>
            <h2 class="display-4 fw-bold mb-3">Our Premium Services</h2>
            <p class="text-muted">We provide comprehensive construction services tailored to meet your specific needs</p>
        </div>
        <div class="row g-4">
            ${(() => {
                if (services && services.length > 0) {
                    return services.slice(0, 6).map((service, index) => {
                        // Helper function to get proper icon class
                        const getIconClass = (icon) => {
                            if (!icon) return 'fas fa-home';
                            
                            // If icon already has a prefix (like 'fab fa-facebook' or 'far fa-heart')
                            if (icon.includes(' ')) {
                                return icon;
                            }
                            
                            // If icon is just the name without fa- prefix
                            if (!icon.startsWith('fa-')) {
                                return `fas fa-${icon}`;
                            }
                            
                            // If icon starts with fa- (like 'fa-home')
                            return `fas ${icon}`;
                        };
                        
                        // Get the icon class for this service
                        const iconClass = getIconClass(service.icon);
                        
                        return `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                                <div class="service-card-modern bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                    <div class="service-card-img position-relative overflow-hidden">
                                        ${service.images && service.images[0] ? `
                                            <img src="${service.images[0].url}" class="img-fluid w-100" alt="${service.title}" style="height: 220px; width: 100%; object-fit: cover;">
                                        ` : `
                                            <img src="/frontend/img/service-${(index % 6) + 1}.jpg" class="img-fluid w-100" alt="Service" style="height: 220px; width: 100%; object-fit: cover;">
                                        `}
                                        <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                            <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                                                <i class="${iconClass} text-white fa-2x"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="service-card-content p-4">
                                        <h4 class="mb-3 fw-bold">${service.title}</h4>
                                        <p class="text-muted mb-4">${service.shortDescription || service.description ? (service.description || service.shortDescription).substring(0, 100) + '...' : 'Quality service delivered with excellence.'}</p>
                                        <a href="/services/${service.id}" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join('');
                } else {
                    return `
                        <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                            <div class="service-card-modern bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                <div class="service-card-img position-relative overflow-hidden">
                                    <img src="/frontend/img/service-1.jpg" class="img-fluid w-100" alt="General Construction" style="height: 220px; width: 100%; object-fit: cover;">
                                    <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                        <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                                            <i class="fas fa-home text-white fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="service-card-content p-4">
                                    <h4 class="mb-3 fw-bold">General Construction</h4>
                                    <p class="text-muted mb-4">Expert general construction services for residential and commercial projects with quality assurance.</p>
                                    <a href="#" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                            <div class="service-card-modern bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                <div class="service-card-img position-relative overflow-hidden">
                                    <img src="/frontend/img/service-2.jpg" class="img-fluid w-100" alt="Property Maintenance" style="height: 220px; width: 100%; object-fit: cover;">
                                    <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                        <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                                            <i class="fas fa-tools text-white fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="service-card-content p-4">
                                    <h4 class="mb-3 fw-bold">Property Maintenance</h4>
                                    <p class="text-muted mb-4">Complete property maintenance services to keep your buildings in perfect condition.</p>
                                    <a href="#" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                            <div class="service-card-modern bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                <div class="service-card-img position-relative overflow-hidden">
                                    <img src="/frontend/img/service-3.jpg" class="img-fluid w-100" alt="Project Management" style="height: 220px; width: 100%; object-fit: cover;">
                                    <div class="service-icon-modern position-absolute start-0 bottom-0 mb-3 ms-3">
                                        <div class="bg-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                                            <i class="fas fa-chart-line text-white fa-2x"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="service-card-content p-4">
                                    <h4 class="mb-3 fw-bold">Project Management</h4>
                                    <p class="text-muted mb-4">Professional project management services ensuring timely delivery and quality control.</p>
                                    <a href="#" class="btn btn-outline-primary rounded-pill px-4">Learn More <i class="fas fa-arrow-right ms-2"></i></a>
                                </div>
                            </div>
                        </div>
                    `;
                }
            })()}
            <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.2s">
                <a class="btn btn-primary rounded-pill px-5 py-3 mt-4" href="/services">View All Services <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
        </div>
    </div>
</div>
    <!-- Services Section End -->

    <!-- Projects Section Start -->
    <div class="container-fluid projects-modern py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">Our Portfolio</span>
                <h2 class="display-4 fw-bold mb-3">Latest Projects</h2>
                <p class="text-muted">Discover our exceptional construction projects that showcase our commitment to quality</p>
            </div>
            <div class="row g-4">
                ${(() => {
                    if (projects && projects.length > 0) {
                        return projects.slice(0, 6).map((project, index) => `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                                <div class="project-card bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        ${project.images && project.images[0] ? `
                                            <img src="${project.images[0].url}" class="img-fluid w-100" alt="${project.title}" style="height: 250px; width: 100%; object-fit: cover;">
                                        ` : `
                                            <img src="/frontend/img/project-${(index % 3) + 1}.jpg" class="img-fluid w-100" alt="Project" style="height: 250px; width: 100%; object-fit: cover;">
                                        `}
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75">
                                            <a href="/projects/${project.id}" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-${project.status === 'completed' ? 'success' : (project.status === 'ongoing' ? 'warning' : 'secondary')} text-white small fw-bold">${project.status}</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">${project.location}</span>
                                        </div>
                                        <h5 class="mb-2 fw-bold">${project.title}</h5>
                                        <p class="text-muted small mb-3">${project.description ? project.description.substring(0, 80) + '...' : 'Quality construction project delivered with excellence.'}</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">${new Date(project.startDate).toLocaleDateString()}</span>
                                            </div>
                                            <a href="/projects/${project.id}" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        return `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                                <div class="project-card bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        <img src="/frontend/img/project-1.jpg" class="img-fluid w-100" alt="Residential Complex" style="height: 250px; width: 100%; object-fit: cover;">
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75">
                                            <a href="#" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-success text-white small fw-bold">Completed</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">Chennai, India</span>
                                        </div>
                                        <h5 class="mb-2 fw-bold">Residential Complex</h5>
                                        <p class="text-muted small mb-3">Modern residential complex with luxury amenities and green spaces.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">Jan 2024</span>
                                            </div>
                                            <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                                <div class="project-card bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        <img src="/frontend/img/project-2.jpg" class="img-fluid w-100" alt="Commercial Tower" style="height: 250px; width: 100%; object-fit: cover;">
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75">
                                            <a href="#" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-warning text-white small fw-bold">Ongoing</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">Bangalore, India</span>
                                        </div>
                                        <h5 class="mb-2 fw-bold">Commercial Tower</h5>
                                        <p class="text-muted small mb-3">Commercial office tower with modern architecture and facilities.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">Mar 2024</span>
                                            </div>
                                            <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                                <div class="project-card bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        <img src="/frontend/img/project-3.jpg" class="img-fluid w-100" alt="Educational Institution" style="height: 250px; width: 100%; object-fit: cover;">
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75">
                                            <a href="#" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-success text-white small fw-bold">Completed</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">Hyderabad, India</span>
                                        </div>
                                        <h5 class="mb-2 fw-bold">Educational Institution</h5>
                                        <p class="text-muted small mb-3">Modern educational facility with state-of-the-art infrastructure.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">Jun 2024</span>
                                            </div>
                                            <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                })()}
            </div>
        </div>
    </div>
    <!-- Projects Section End -->

    <!-- Blog Section Start -->
    <div class="container-fluid blog-modern py-5 bg-light">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">News & Blog</span>
                <h2 class="display-4 fw-bold mb-3">Latest Articles</h2>
                <p class="text-muted">Stay updated with our latest news and industry insights</p>
            </div>
            <div class="row g-4">
                ${(() => {
                    if (latestArticles && latestArticles.length > 0) {
                        return latestArticles.map(article => `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                                <div class="blog-card bg-white rounded-4 overflow-hidden shadow-sm h-100">
                                    <div class="blog-img position-relative overflow-hidden">
                                        ${article.images && article.images[0] ? `
                                            <img src="${article.images[0].url}" class="img-fluid w-100" alt="${article.title}" style="height: 220px; width: 100%; object-fit: cover;">
                                        ` : `
                                            <img src="/frontend/img/blog-1.jpg" class="img-fluid w-100" alt="Blog" style="height: 220px; width: 100%; object-fit: cover;">
                                        `}
                                    </div>
                                    <div class="blog-content p-4">
                                        <div class="d-flex justify-content-between mb-3">
