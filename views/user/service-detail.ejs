<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">${service.title}</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/services">Services</a></li>
                <li class="breadcrumb-item text-secondary active">${service.title}</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- Service Detail Start -->
    <div class="container-fluid service-detail py-5">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-8">
                    ${(() => {
                        if (service.images && service.images[0]) {
                            return `<img src="${service.images[0].url}" class="img-fluid w-100 rounded mb-4" alt="${service.title}" style="height: 400px; object-fit: cover;">`;
                        } else {
                            return `<img src="/frontend/img/service-1.jpg" class="img-fluid w-100 rounded mb-4" alt="${service.title}" style="height: 400px; object-fit: cover;">`;
                        }
                    })()}
                    <h2 class="mb-3">${service.title}</h2>
                    ${service.subtitle ? `<h5 class="text-secondary mb-4">${service.subtitle}</h5>` : ''}
                    <p class="mb-4">${service.description || 'Quality service delivered with excellence and commitment.'}</p>

                    ${(() => {
                        if (service.features && service.features.length > 0) {
                            return `
                                <h4 class="mb-3">Key Features</h4>
                                <ul class="list-unstyled">
                                    ${service.features.map(feature => `
                                        <li class="mb-2"><i class="fas fa-check-circle text-secondary me-2"></i> ${feature}</li>
                                    `).join('')}
                                </ul>
                            `;
                        } else {
                            return '';
                        }
                    })()}
                </div>
                <div class="col-lg-4">
                    <div class="bg-light p-4 rounded">
                        <h4 class="mb-4">Service Information</h4>
                        <div class="mb-3">
                            <i class="fas fa-tag text-secondary me-2"></i>
                            <strong>Category:</strong> ${service.category || 'Construction'}
                        </div>
                        <div class="mb-3">
                            <i class="fas fa-clock text-secondary me-2"></i>
                            <strong>Duration:</strong> As per project requirements
                        </div>
                        <div class="mb-3">
                            <i class="fas fa-users text-secondary me-2"></i>
                            <strong>Team:</strong> Expert Engineers & Workers
                        </div>
                        <hr>
                        <a href="/contact" class="btn btn-secondary w-100 py-3">Get Quote</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Service Detail End -->
` }) %>