<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">About Us</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item text-secondary active">About</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- About Section Start -->
    <div class="container-fluid about-modern py-5">
        <div class="container py-5">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6 wow fadeInLeft" data-wow-delay="0.1s">
                    <div class="about-image-wrapper position-relative">
                        <div class="about-image-main position-relative">
                            ${about.images && about.images[0] ? `
                                <img src="${about.images[0].url}" class="img-fluid rounded-3 shadow-lg w-100" alt="${about.title}" style="height: 500px; width: 100%; object-fit: cover;">
                            ` : `
                                <img src="/frontend/img/about-main.jpg" class="img-fluid rounded-3 shadow-lg w-100" alt="About" style="height: 500px; width: 100%; object-fit: cover;">
                            `}
                        </div>
                        <div class="about-experience-badge position-absolute bg-primary text-white rounded-3 p-4 shadow-lg">
                            <h2 class="display-4 fw-bold mb-0">${about.yearsOfExperience || '15'}</h2>
                            <p class="mb-0">Years of<br>Experience</p>
                        </div>
                        <div class="about-image-secondary position-absolute">
                            ${about.images && about.images[1] ? `
                                <img src="${about.images[1].url}" class="img-fluid rounded-3 shadow-lg" alt="${about.title}" style="width: 180px; height: 180px; object-fit: cover;">
                            ` : `
                                <img src="/frontend/img/about-secondary.jpg" class="img-fluid rounded-3 shadow-lg" alt="About" style="width: 180px; height: 180px; object-fit: cover;">
                            `}
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 wow fadeInRight" data-wow-delay="0.1s">
                    <div class="about-content">
                        <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">About Company</span>
                        <h2 class="display-4 fw-bold mb-3">${about.title || 'Building Excellence Since 2010'}</h2>
                        <p class="lead text-secondary mb-4">${about.subtitle || 'We create exceptional spaces that inspire and endure.'}</p>
                        <p class="text-muted mb-4">${about.longDescription || about.shortDescription || 'Thirupathi Constructions is a premier construction company dedicated to delivering quality projects with integrity, innovation, and excellence. We transform visions into reality through our commitment to craftsmanship and client satisfaction.'}</p>
                        <div class="row g-4 mb-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0 bg-primary rounded-circle p-3 me-3">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M20 6L9 17L4 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1">Quality Assurance</h5>
                                        <p class="text-muted mb-0">Highest quality standards</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0 bg-primary rounded-circle p-3 me-3">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <circle cx="12" cy="12" r="10" stroke="white" stroke-width="1.5"/>
                                            <polyline points="12 6 12 12 16 14" stroke="white" stroke-width="1.5"/>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1">Timely Delivery</h5>
                                        <p class="text-muted mb-0">On-time project completion</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0 bg-primary rounded-circle p-3 me-3">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M20 21V19C20 16.8 18.2 15 16 15H8C5.8 15 4 16.8 4 19V21" stroke="white" stroke-width="1.5"/>
                                            <path d="M12 11C14.2091 11 16 9.20914 16 7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7C8 9.20914 9.79086 11 12 11Z" stroke="white" stroke-width="1.5"/>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1">Expert Team</h5>
                                        <p class="text-muted mb-0">Skilled professionals</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0 bg-primary rounded-circle p-3 me-3">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M12 2L15 8H9L12 2Z" fill="white"/>
                                            <path d="M12 22L9 16H15L12 22Z" fill="white"/>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="mb-1">Client Satisfaction</h5>
                                        <p class="text-muted mb-0">100% satisfaction guarantee</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-3">
                            <a href="/services" class="btn btn-primary rounded-pill px-5 py-3">Our Services <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: inline-block; margin-left: 8px;"><path d="M5 12H19" stroke="white" stroke-width="1.5" stroke-linecap="round"/><path d="M12 5L19 12L12 19" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                            <a href="/contact" class="btn btn-outline-primary rounded-pill px-5 py-3">Contact Us</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
