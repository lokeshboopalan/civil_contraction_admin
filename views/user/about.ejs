                                <path d="M12 2L15 8H9L12 2Z" fill="#0d6efd"/>
                                <path d="M12 22L9 16H15L12 22Z" fill="#0d6efd"/>
                                <rect x="4" y="8" width="16" height="8" rx="1" fill="#0d6efd" fill-opacity="0.3" stroke="#0d6efd" stroke-width="1.5"/>
                                <circle cx="12" cy="12" r="2" fill="#0d6efd"/>
                            </svg>
                        </div>
                        <h3 class="mb-3">Our Mission</h3>
                        <p class="text-muted mb-0">${about.missionStatement || 'To deliver exceptional construction services with integrity, quality, and innovation, exceeding client expectations and building lasting relationships.'}</p>
                    </div>
                </div>
                <div class="col-lg-6 wow fadeInRight" data-wow-delay="0.2s">
                    <div class="vision-card bg-white rounded-4 p-5 h-100 shadow-sm">
                        <div class="icon-wrapper bg-primary bg-opacity-10 rounded-circle p-4 mb-4 d-inline-flex align-items-center justify-content-center" style="width: 90px; height: 90px;">
                            <svg width="45" height="45" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="3" fill="#0d6efd"/>
                                <path d="M12 4C7.5 4 3.5 7 2 12C3.5 17 7.5 20 12 20C16.5 20 20.5 17 22 12C20.5 7 16.5 4 12 4Z" stroke="#0d6efd" stroke-width="1.5" fill="none"/>
                            </svg>
                        </div>
                        <h3 class="mb-3">Our Vision</h3>
                        <p class="text-muted mb-0">${about.visionStatement || 'To be the most trusted and innovative construction company, setting new standards in quality and sustainability while transforming skylines across the nation.'}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Mission & Vision End -->

    <!-- Core Values Start -->
    <div class="container-fluid core-values-modern py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">Our Principles</span>
                <h2 class="display-4 fw-bold mb-3">Core Values</h2>
                <p class="text-muted">The foundation of everything we do</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="value-card text-center p-4">
                        <div class="value-icon bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 2L15 8H9L12 2Z" fill="#0d6efd"/>
                                <rect x="4" y="8" width="16" height="8" rx="1" fill="#0d6efd" fill-opacity="0.3" stroke="#0d6efd"/>
                                <circle cx="12" cy="12" r="2" fill="#0d6efd"/>
                            </svg>
                        </div>
                        <h4 class="mb-3">Integrity</h4>
                        <p class="text-muted">We conduct business with honesty, transparency, and ethical practices in all our dealings.</p>
                    </div>
                </div>
                <div class="col-md-4 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="value-card text-center p-4">
                        <div class="value-icon bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="8" r="4" stroke="#0d6efd"/>
                                <path d="M5 20V19C5 15.1 8.1 12 12 12C15.9 12 19 15.1 19 19V20" stroke="#0d6efd"/>
                                <path d="M16 4L18 6L22 2" stroke="#0d6efd"/>
                            </svg>
                        </div>
                        <h4 class="mb-3">Excellence</h4>
                        <p class="text-muted">We strive for excellence in every project, pushing boundaries and exceeding expectations.</p>
                    </div>
                </div>
                <div class="col-md-4 wow fadeInUp" data-wow-delay="0.4s">
                    <div class="value-card text-center p-4">
                        <div class="value-icon bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="4" stroke="#0d6efd"/>
                                <path d="M12 8L12 12L14 14" stroke="#0d6efd"/>
                            </svg>
                        </div>
                        <h4 class="mb-3">Client Focus</h4>
                        <p class="text-muted">We prioritize client satisfaction and build lasting relationships through exceptional service.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Core Values End -->

    <!-- Stats Section -->
    <div class="container-fluid stats-section py-5 bg-primary">
        <div class="container py-5">
            <div class="row g-4 text-center">
                <div class="col-md-3 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="stat-item">
                        <h2 class="display-2 fw-bold text-white mb-2">${about.completedProjects || '150'}+</h2>
                        <p class="text-white mb-0">Projects Completed</p>
                    </div>
                </div>
                <div class="col-md-3 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="stat-item">
                        <h2 class="display-2 fw-bold text-white mb-2">${about.happyClients || '120'}+</h2>
                        <p class="text-white mb-0">Happy Clients</p>
                    </div>
                </div>
                <div class="col-md-3 wow fadeInUp" data-wow-delay="0.4s">
                    <div class="stat-item">
                        <h2 class="display-2 fw-bold text-white mb-2">${about.experiencedStaff || '50'}+</h2>
                        <p class="text-white mb-0">Expert Staff</p>
                    </div>
                </div>
                <div class="col-md-3 wow fadeInUp" data-wow-delay="0.5s">
                    <div class="stat-item">
                        <h2 class="display-2 fw-bold text-white mb-2">${about.yearsExperience || '15'}</h2>
                        <p class="text-white mb-0">Years Experience</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Stats End -->

    <!-- Why Choose Us Section -->
    <div class="container-fluid why-choose-us py-5 bg-light">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">Why Choose Us</span>
                <h2 class="display-4 fw-bold mb-3">Why Thirupathi Constructions</h2>
                <p class="text-muted">What sets us apart from the competition</p>
            </div>
            <div class="row g-4">
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="choose-card text-center p-4 bg-white rounded-4 shadow-sm h-100">
                        <div class="choose-icon bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 21V19C20 16.8 18.2 15 16 15H8C5.8 15 4 16.8 4 19V21" stroke="#0d6efd"/>
                                <path d="M12 11C14.2091 11 16 9.20914 16 7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7C8 9.20914 9.79086 11 12 11Z" stroke="#0d6efd"/>
                            </svg>
                        </div>
                        <h5 class="mb-3 fw-bold">Expert Engineers</h5>
                        <p class="text-muted mb-0">Professional and experienced engineers dedicated to quality construction.</p>
                    </div>
                </div>
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="choose-card text-center p-4 bg-white rounded-4 shadow-sm h-100">
                        <div class="choose-icon bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="4" y="10" width="16" height="10" rx="2" stroke="#0d6efd"/>
                                <path d="M12 14V16" stroke="#0d6efd"/>
                                <path d="M8 14H16" stroke="#0d6efd"/>
                            </svg>
                        </div>
                        <h5 class="mb-3 fw-bold">Free Estimates</h5>
                        <p class="text-muted mb-0">Get free project estimates and consultation before starting.</p>
                    </div>
                </div>
                <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.4s">
                    <div class="choose-card text-center p-4 bg-white rounded-4 shadow-sm h-100">
                        <div class="choose-icon bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="3" stroke="#0d6efd"/>
                                <path d="M12 3V5" stroke="#0d6efd"/>
                                <path d="M18 6L16 8" stroke="#0d6efd"/>
                                <path d="M6 6L8 8" stroke="#0d6efd"/>
                            </svg>
                        </div>
                        <h5 class="mb-3 fw-bold">Quality Materials</h5>
                        <p class="text-muted mb-0">We use only the highest quality materials for all projects.</p>
