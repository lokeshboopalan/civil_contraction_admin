                <span class="badge bg-primary text-white px-4 py-2 rounded-pill mb-3">Our Purpose</span>
                <h2 class="display-4 fw-bold mb-3">Mission & Vision</h2>
                <p class="text-muted">Driven by purpose, guided by values</p>
            </div>
            <div class="row g-4">
                <div class="col-lg-6 wow fadeInLeft" data-wow-delay="0.1s">
