<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: `
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">Our Projects</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item text-secondary active">Projects</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- Projects Start -->
    <div class="container-fluid projects py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">Our Portfolio</p>
                <h2 class="display-4 text-capitalize mb-3">Latest Projects</h2>
                <p class="mb-0">Discover our exceptional construction projects that showcase our commitment to quality and innovation.</p>
            </div>
            <div class="row g-4">
                ${(() => {
                    if (projects && projects.length > 0) {
                        return projects.map((project, index) => `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                                <div class="project-card bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        ${project.images && project.images[0] ? `
                                            <img src="${project.images[0].url}" class="img-fluid w-100" alt="${project.title}" style="height: 250px; width: 100%; object-fit: cover; transition: transform 0.5s ease;">
                                        ` : `
                                            <img src="/frontend/img/project-${(index % 3) + 1}.jpg" class="img-fluid w-100" alt="Project" style="height: 250px; width: 100%; object-fit: cover;">
                                        `}
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75 opacity-0 transition-all">
                                            <a href="/projects/${project.id}" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-${project.status === 'completed' ? 'success' : (project.status === 'ongoing' ? 'warning' : 'secondary')} text-white small fw-bold">${project.status}</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">${project.location}</span>
                                        </div>
                                        <h5 class="mb-2">
                                            <a href="/projects/${project.id}" class="text-dark text-decoration-none hover-primary">${project.title}</a>
                                        </h5>
                                        <p class="text-muted small mb-3">${project.description ? project.description.substring(0, 80) + '...' : 'Quality construction project delivered with excellence.'}</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">${new Date(project.startDate).toLocaleDateString()}</span>
                                            </div>
                                            <a href="/projects/${project.id}" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        return `
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                                <div class="project-card bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        <img src="/frontend/img/project-1.jpg" class="img-fluid w-100" alt="Residential Complex" style="height: 250px; width: 100%; object-fit: cover;">
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75 opacity-0 transition-all">
                                            <a href="#" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-success text-white small fw-bold">Completed</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">Chennai, India</span>
                                        </div>
                                        <h5 class="mb-2">
                                            <a href="#" class="text-dark text-decoration-none hover-primary">Residential Complex</a>
                                        </h5>
                                        <p class="text-muted small mb-3">Modern residential complex with luxury amenities and green spaces.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">Jan 2024</span>
                                            </div>
                                            <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                                <div class="project-card bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        <img src="/frontend/img/project-2.jpg" class="img-fluid w-100" alt="Commercial Tower" style="height: 250px; width: 100%; object-fit: cover;">
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75 opacity-0 transition-all">
                                            <a href="#" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-warning text-white small fw-bold">Ongoing</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">Bangalore, India</span>
                                        </div>
                                        <h5 class="mb-2">
                                            <a href="#" class="text-dark text-decoration-none hover-primary">Commercial Tower</a>
                                        </h5>
                                        <p class="text-muted small mb-3">Commercial office tower with modern architecture and facilities.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">Mar 2024</span>
                                            </div>
                                            <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                                <div class="project-card bg-white rounded overflow-hidden shadow-sm h-100">
                                    <div class="project-img position-relative overflow-hidden">
                                        <img src="/frontend/img/project-3.jpg" class="img-fluid w-100" alt="Educational Institution" style="height: 250px; width: 100%; object-fit: cover;">
                                        <div class="project-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-75 opacity-0 transition-all">
                                            <a href="#" class="btn btn-primary rounded-pill px-4 py-2">View Details</a>
                                        </div>
                                        <span class="project-status position-absolute top-0 end-0 m-3 px-3 py-1 rounded-pill bg-success text-white small fw-bold">Completed</span>
                                    </div>
                                    <div class="project-info p-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                                            <span class="text-muted small">Hyderabad, India</span>
                                        </div>
                                        <h5 class="mb-2">
                                            <a href="#" class="text-dark text-decoration-none hover-primary">Educational Institution</a>
                                        </h5>
                                        <p class="text-muted small mb-3">Modern educational facility with state-of-the-art infrastructure.</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex gap-2">
                                                <i class="fas fa-calendar-alt text-muted small"></i>
                                                <span class="text-muted small">Jun 2024</span>
                                            </div>
                                            <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Read More <i class="fas fa-arrow-right ms-1"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                })()}
            </div>
        </div>
    </div>
    <!-- Projects End -->
` }) %>