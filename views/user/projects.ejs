<%- include('../layouts/frontend', { title: title, currentPage: currentPage, body: ` <!-- Spinner Start -->
    <div id="spinner"
        class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <!-- Topbar Start -->
    <div class="container-fluid topbar d-none d-xl-block w-100">
        <div class="row gx-0 align-items-center" style="height: 45px;">
            <div class="col-lg-6 text-center text-lg-start mb-lg-0">
                <div class="d-flex flex-wrap">
                    <a href="#" class="text-muted me-4"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Find A
                        Location</a>
                    <a href="#" class="text-muted me-4"><i
                            class="fas fa-phone-alt text-secondary me-2"></i>+01234567890</a>
                    <a href="#" class="text-muted me-0"><i
                            class="fas fa-envelope text-secondary me-2"></i>Example@gmail.com</a>
                </div>
            </div>
            <div class="col-lg-6 text-center text-lg-end">
                <div class="d-flex align-items-center justify-content-end">
                    <a href="#" class="text-muted me-3"><i class="fas fa-clock text-secondary me-2"></i>Mon - Sat 8:00 -
                        17:30, Sunday - CLOSED</a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-facebook-f"></i></a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-twitter"></i></a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-instagram"></i></a>
                    <a href="#" class="btn btn-primary btn-square border border-white me-3"><i
                            class="fab fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>
    </div>
    <!-- Topbar End -->

    <!-- Navbar & Hero Start -->
    <div class="container-fluid sticky-top px-0">
        <nav class="navbar navbar-expand-lg navbar-dark bg-light py-3 px-4">
            <a href="/" class="navbar-brand p-0">
                <h1 class="text-secondary display-6"><i class="fas fa-city text-primary me-3"></i>Thirupathi</h1>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="fa fa-bars"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <div class="navbar-nav ms-auto pt-2 pt-lg-0">
                    <a href="/" class="nav-item nav-link ${currentPage === 'home' ? 'active' : ''}">Home</a>
                    <a href="/about" class="nav-item nav-link ${currentPage === 'about' ? 'active' : ''}">About</a>
                    <a href="/services"
                        class="nav-item nav-link ${currentPage === 'services' ? 'active' : ''}">Services</a>
                    <a href="/projects"
                        class="nav-item nav-link ${currentPage === 'projects' ? 'active' : ''}">Projects</a>
                    <a href="/articles" class="nav-item nav-link ${currentPage === 'articles' ? 'active' : ''}">Blog</a>
                    <a href="/contact"
                        class="nav-item nav-link ${currentPage === 'contact' ? 'active' : ''}">Contact</a>
                </div>
            </div>
        </nav>
    </div>
    <!-- Navbar & Hero End -->

    <!-- Header Start -->
    <div class="container-fluid bg-breadcrumb">
        <div class="container text-center py-5" style="max-width: 900px;">
            <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">Our Projects</h4>
            <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item text-secondary active">Projects</li>
            </ol>
        </div>
    </div>
    <!-- Header End -->

    <!-- Projects/Features Start -->
    <div class="container-fluid feature bg-light py-5">
        <div class="container py-5">
            <div class="text-center mx-auto pb-5 wow fadeInUp" data-wow-delay="0.2s" style="max-width: 800px;">
                <p class="text-uppercase text-secondary fs-5 mb-0">Our Portfolio</p>
                <h2 class="display-4 text-capitalize mb-3">Latest Projects</h2>
            </div>
            <div class="row g-4">
                ${projects && projects.length > 0 ? projects.map((project, index) => `
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="${0.2 + (index * 0.1)}s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            ${project.images && project.images[0] ? `
                            <img src="${project.images[0].url}" class="img-fluid" alt="${project.title}"
                                style="width: 80px; height: 80px; object-fit: cover; border-radius: 10px;">
                            ` : `
                            <i class="fas fa-building text-primary fa-5x"></i>
                            `}
                        </div>
                        <a href="/projects/${project.id}" class="h4 d-block my-4">${project.title}</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>${project.location}</p>
                        <p class="mb-3">${project.description ? project.description.substring(0, 100) : 'Quality
                            construction project delivered with excellence.'}</p>
                        <span class="badge bg-primary mb-3">${project.status}</span>
                        <a href="/projects/${project.id}" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                `).join('') : `
                <!-- Default Projects when no data -->
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.2s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-building text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Residential Complex</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Chennai, India</p>
                        <p class="mb-3">Modern residential complex with luxury amenities and green spaces.</p>
                        <span class="badge bg-primary mb-3">Completed</span>
                        <a href="#" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.4s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-hospital text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Commercial Tower</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Bangalore, India</p>
                        <p class="mb-3">Commercial office tower with modern architecture and facilities.</p>
                        <span class="badge bg-primary mb-3">Ongoing</span>
                        <a href="#" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.6s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-school text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Educational Institution</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Hyderabad, India</p>
                        <p class="mb-3">Modern educational facility with state-of-the-art infrastructure.</p>
                        <span class="badge bg-primary mb-3">Completed</span>
                        <a href="#" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-hotel text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Luxury Hotel</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Goa, India</p>
                        <p class="mb-3">Beachfront luxury hotel with premium amenities and design.</p>
                        <span class="badge bg-primary mb-3">Ongoing</span>
                        <a href="#" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-industry text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Industrial Park</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Pune, India</p>
                        <p class="mb-3">Industrial park with modern manufacturing facilities.</p>
                        <span class="badge bg-primary mb-3">Upcoming</span>
                        <a href="#" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.7s">
                    <div class="feature-item text-center border p-5">
                        <div class="feature-img bg-secondary d-inline-flex p-4">
                            <i class="fas fa-home text-primary fa-5x"></i>
                        </div>
                        <a href="#" class="h4 d-block my-4">Affordable Housing</a>
                        <p class="mb-3"><i class="fas fa-map-marker-alt text-secondary me-2"></i>Mumbai, India</p>
                        <p class="mb-3">Affordable housing project for middle-income families.</p>
                        <span class="badge bg-primary mb-3">Completed</span>
                        <a href="#" class="btn btn-primary py-2 px-4 mt-2">View Details</a>
                    </div>
                </div>
                `}
                <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.2s">
                    <a class="btn btn-secondary py-3 px-5 mt-4" href="/projects">Load More Projects</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Projects/Features End -->
    ` }) %>