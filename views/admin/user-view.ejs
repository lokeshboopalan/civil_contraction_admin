<%- include('../layouts/admin-users', { 
    title: 'View User',
    currentPage: 'users',
    user: typeof user !== 'undefined' ? user : null,
    body: `
        <div class="container-fluid pt-4 px-4">
            <div class="row justify-content-center">
                <div class="col-sm-12 col-xl-8">
                    <div class="bg-light rounded h-100 p-4">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h5 class="mb-0">User Details</h5>
                            <div>
                                <a href="/admin/users" class="btn btn-sm btn-secondary me-2">
                                    <i class="fa fa-arrow-left me-2"></i>Back
                                </a>
                                <a href="/admin/users/edit/${userData.id}" class="btn btn-sm btn-warning">
                                    <i class="fa fa-edit me-2"></i>Edit
                                </a>
                            </div>
                        </div>
                        
                        <div class="card">
                            <div class="card-body">
                                <div class="text-center mb-4">
                                    <div class="position-relative d-inline-block">
                                        <img class="rounded-circle" src="/img/user.jpg" alt="" style="width: 100px; height: 100px;">
                                        <span class="position-absolute bottom-0 end-0 bg-success rounded-circle p-2 border border-2 border-white"></span>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <h6 class="mb-0"><i class="fa fa-id-card me-2 text-primary"></i>User ID</h6>
                                    </div>
                                    <div class="col-sm-8 text-secondary">
                                        ${userData.id}
                                    </div>
                                </div>
                                <hr>
                                
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <h6 class="mb-0"><i class="fa fa-user me-2 text-primary"></i>Full Name</h6>
                                    </div>
                                    <div class="col-sm-8 text-secondary">
                                        ${userData.name}
                                    </div>
                                </div>
                                <hr>
                                
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <h6 class="mb-0"><i class="fa fa-envelope me-2 text-primary"></i>Email Address</h6>
                                    </div>
                                    <div class="col-sm-8 text-secondary">
                                        ${userData.email}
                                    </div>
                                </div>
                                <hr>
                                
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <h6 class="mb-0"><i class="fa fa-tag me-2 text-primary"></i>Role</h6>
                                    </div>
                                    <div class="col-sm-8 text-secondary">
                                        <span class="badge bg-${userData.role === 'admin' ? 'primary' : 'secondary'} p-2">
                                            ${userData.role}
                                        </span>
                                    </div>
                                </div>
                                <hr>
                                
                                <div class="row">
                                    <div class="col-sm-12">
                                        <div class="alert alert-info mb-0">
                                            <i class="fa fa-info-circle me-2"></i>
                                            Password is encrypted and cannot be displayed for security reasons.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4 text-center">
                            <button class="btn btn-danger" onclick="deleteUser(${userData.id})">
                                <i class="fa fa-trash me-2"></i>Delete User
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
        function deleteUser(id) {
            if (confirm('Are you sure you want to delete this user?')) {
                window.location.href = '/admin/users/delete/' + id;
            }
        }
        </script>
    `
}) %>