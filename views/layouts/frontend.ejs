            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
        }
        .btn-square svg {
            width: 14px;
            height: 14px;
        }
        .footer {
            background-color: #1a2c3e;
            color: #ffffff;
        }
        .footer a {
            color: #ffffff;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .footer a:hover {
            color: #ffc107;
        }
        .footer-btn .btn {
            width: 40px;
            height: 40px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s ease;
        }
        .footer-btn .btn:hover {
