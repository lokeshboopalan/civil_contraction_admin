<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-8">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0">Article Details</h5>
                    <a href="/admin/articles" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <!-- Images Gallery -->
                <% if (articleData.images && articleData.images.length > 0) { %>
                    <div class="text-center mb-4">
                        <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                            <% articleData.images.forEach(function(image) { %>
                                <img src="<%= image.url %>" alt="Article Image" 
                                     style="width: 200px; height: 150px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;">
                            <% }); %>
                        </div>
                    </div>
                    <hr>
                <% } %>
                
                <div class="card">
                    <div class="card-body">
                        <h4 class="mb-3"><%= articleData.title %></h4>
                        
                        <% if (articleData.subTitle) { %>
                            <h6 class="text-muted mb-3"><%= articleData.subTitle %></h6>
                        <% } %>
                        
                        <div class="mb-4">
                            <%= articleData.description %>
                        </div>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-4">
                                <p><strong>Role:</strong> 
                                    <span class="badge bg-<%= articleData.role === 'admin' ? 'danger' : (articleData.role === 'editor' ? 'info' : 'secondary') %>">
                                        <%= articleData.role %>
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <p><strong>Status:</strong> 
                                    <span class="badge bg-<%= articleData.isPublished ? 'success' : 'warning' %>">
                                        <%= articleData.isPublished ? 'Published' : 'Draft' %>
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <p><strong>Views:</strong> <%= articleData.views %></p>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Created:</strong> <%= new Date(articleData.createdAt).toLocaleString() %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Last Updated:</strong> <%= new Date(articleData.updatedAt).toLocaleString() %></p>
                            </div>
                        </div>
                        
                        <% if (articleData.publishedAt) { %>
                            <div class="row">
                                <div class="col-md-12">
                                    <p><strong>Published:</strong> <%= new Date(articleData.publishedAt).toLocaleString() %></p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
                
                <div class="mt-3 text-center">
                    <a href="/admin/articles/edit/<%= articleData.id %>" class="btn btn-warning">
                        <i class="fa fa-edit me-2"></i>Edit
                    </a>
                    <form action="/admin/articles/delete/<%= articleData.id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this article?')">
                            <i class="fa fa-trash me-2"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>