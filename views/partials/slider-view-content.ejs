<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-8">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0">Slider Details</h5>
                    <a href="/admin/sliders" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <div class="card">
                    <div class="card-body">
                        <!-- Images Gallery -->
                        <% if (sliderData.images && sliderData.images.length > 0) { %>
                            <div class="text-center mb-4">
                                <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                                    <% sliderData.images.forEach(function(image) { %>
                                        <img src="<%= image.url %>" alt="Slider Image" 
                                             style="width: 200px; height: 150px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;">
                                    <% }); %>
                                </div>
                            </div>
                            <hr>
                        <% } %>
                        
                        <h4 class="mb-3"><%= sliderData.title %></h4>
                        
                        <% if (sliderData.subTitle) { %>
                            <h6 class="text-muted mb-3"><%= sliderData.subTitle %></h6>
                        <% } %>
                        
                        <% if (sliderData.description) { %>
                            <p class="mb-3"><%= sliderData.description %></p>
                        <% } %>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Order:</strong> <%= sliderData.order || 0 %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Status:</strong> 
                                    <span class="badge bg-<%= sliderData.isActive ? 'success' : 'secondary' %>">
                                        <%= sliderData.isActive ? 'Active' : 'Inactive' %>
                                    </span>
                                </p>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Created:</strong> <%= new Date(sliderData.createdAt).toLocaleString() %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Last Updated:</strong> <%= new Date(sliderData.updatedAt).toLocaleString() %></p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-3 text-center">
                    <a href="/admin/sliders/edit/<%= sliderData.id %>" class="btn btn-warning">
                        <i class="fa fa-edit me-2"></i>Edit
                    </a>
                    <form action="/admin/sliders/delete/<%= sliderData.id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this slider?')">
                            <i class="fa fa-trash me-2"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>