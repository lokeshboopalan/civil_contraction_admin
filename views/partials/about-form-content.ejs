<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-10">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0">Edit About Information</h5>
                    <a href="/admin/about" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <form action="/admin/about/update/<%= aboutData.id %>" 
                      method="POST" 
                      enctype="multipart/form-data">
                    
                    <!-- Basic Information -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" value="<%= aboutData.title || '' %>" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Icon (Font Awesome)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa <%= aboutData.icon || 'fa-info-circle' %>"></i></span>
                                <input type="text" class="form-control" name="icon" value="<%= aboutData.icon || '' %>" placeholder="fa-info-circle">
                            </div>
                            <small class="text-muted">Enter Font Awesome icon class</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Subtitle</label>
                        <input type="text" class="form-control" name="subtitle" value="<%= aboutData.subtitle || '' %>">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Short Description</label>
                        <textarea class="form-control" name="shortDescription" rows="3"><%= aboutData.shortDescription || '' %></textarea>
                        <small class="text-muted">Brief description for previews</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Long Description</label>
                        <textarea class="form-control" name="longDescription" rows="6"><%= aboutData.longDescription || '' %></textarea>
                    </div>

                    <!-- Mission, Vision, Core Values -->
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Mission Statement</label>
                            <textarea class="form-control" name="missionStatement" rows="3"><%= aboutData.missionStatement || '' %></textarea>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Vision Statement</label>
                            <textarea class="form-control" name="visionStatement" rows="3"><%= aboutData.visionStatement || '' %></textarea>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Core Values</label>
                            <textarea class="form-control" name="coreValues" rows="3"><%= aboutData.coreValues || '' %></textarea>
                        </div>
                    </div>

                    <!-- Image Upload Section -->
                    <div class="mb-3">
                        <label for="formFileMultiple" class="form-label">About Images</label>
                        <input class="form-control" type="file" name="images" id="formFileMultiple" multiple accept="image/*">
                        <small class="text-muted">You can select multiple images (JPG, PNG, GIF)</small>
                        
                        <!-- Image Preview Container -->
                        <div class="image-preview mt-3" id="imagePreview" style="display: flex; flex-wrap: wrap; gap: 10px;"></div>
                        
                        <!-- Existing Images -->
                        <% if (aboutData.images && aboutData.images.length > 0) { %>
                            <div class="existing-images mt-3">
                                <label class="form-label fw-bold mt-3">Existing Images</label>
                                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                                    <% aboutData.images.forEach(function(image) { %>
                                        <div class="image-item" style="position: relative; margin-bottom: 10px;">
                                            <img src="<%= image.url %>" alt="About Image" 
                                                 style="width: 100px; height: 100px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;">
                                            <button type="button" class="btn btn-sm btn-danger" 
                                                    style="position: absolute; top: -8px; right: -8px; border-radius: 50%; width: 25px; height: 25px; padding: 0; display: flex; align-items: center; justify-content: center;"
                                                    onclick="deleteImage('<%= image.publicId %>', <%= aboutData.id %>)">
                                                <i class="fa fa-times" style="font-size: 12px;"></i>
                                            </button>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- Video & Brochure -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Video URL</label>
                            <input type="url" class="form-control" name="videoUrl" value="<%= aboutData.videoUrl || '' %>" placeholder="https://youtube.com/watch?v=...">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Brochure URL</label>
                            <input type="url" class="form-control" name="brochureUrl" value="<%= aboutData.brochureUrl || '' %>" placeholder="https://example.com/brochure.pdf">
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-control" name="isActive">
                                <option value="true" <%= aboutData.isActive !== false ? 'selected' : '' %>>Active</option>
                                <option value="false" <%= aboutData.isActive === false ? 'selected' : '' %>>Inactive</option>
                            </select>
                        </div>
                    </div>

                    <!-- Social Links Section -->
                    <div class="mb-4">
                        <h6 class="mb-3">Social Media Links</h6>
                        <div id="social-links-container">
                            <% if (aboutData.socialLinks && aboutData.socialLinks.length > 0) { %>
                                <% aboutData.socialLinks.forEach(function(link, index) { %>
                                    <div class="social-link-item border rounded p-3 mb-3">
                                        <div class="row">
                                            <div class="col-md-3 mb-2">
                                                <label class="form-label">Platform</label>
                                                <select class="form-control" name="socialLinks[<%= index %>][platform]" onchange="updateIcon(this)">
                                                    <option value="facebook" <%= link.platform === 'facebook' ? 'selected' : '' %>>Facebook</option>
                                                    <option value="twitter" <%= link.platform === 'twitter' ? 'selected' : '' %>>Twitter</option>
                                                    <option value="linkedin" <%= link.platform === 'linkedin' ? 'selected' : '' %>>LinkedIn</option>
                                                    <option value="instagram" <%= link.platform === 'instagram' ? 'selected' : '' %>>Instagram</option>
                                                    <option value="youtube" <%= link.platform === 'youtube' ? 'selected' : '' %>>YouTube</option>
                                                    <option value="github" <%= link.platform === 'github' ? 'selected' : '' %>>GitHub</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4 mb-2">
                                                <label class="form-label">URL</label>
                                                <input type="url" class="form-control" name="socialLinks[<%= index %>][url]" value="<%= link.url %>" required>
                                            </div>
                                            <div class="col-md-3 mb-2">
                                                <label class="form-label">Icon</label>
                                                <input type="text" class="form-control" name="socialLinks[<%= index %>][icon]" value="<%= link.icon %>" readonly>
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="form-label">Active</label>
                                                <select class="form-control" name="socialLinks[<%= index %>][isActive]">
                                                    <option value="true" <%= link.isActive !== false ? 'selected' : '' %>>Yes</option>
                                                    <option value="false" <%= link.isActive === false ? 'selected' : '' %>>No</option>
                                                </select>
                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeSocialLink(this)">
                                            <i class="fa fa-trash me-2"></i>Remove
                                        </button>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                        <button type="button" class="btn btn-sm btn-success" onclick="addSocialLink()">
                            <i class="fa fa-plus me-2"></i>Add Social Link
                        </button>
                    </div>

                    <!-- Team Members Section -->
                    <div class="mb-4">
                        <h6 class="mb-3">Team Members</h6>
                        <div id="team-members-container">
                            <% if (aboutData.teamMembers && aboutData.teamMembers.length > 0) { %>
                                <% aboutData.teamMembers.forEach(function(member, index) { %>
                                    <div class="team-member-item border rounded p-3 mb-3">
                                        <div class="row">
                                            <div class="col-md-4 mb-2">
                                                <label class="form-label">Name</label>
                                                <input type="text" class="form-control" name="teamMembers[<%= index %>][name]" value="<%= member.name %>" required>
                                            </div>
                                            <div class="col-md-4 mb-2">
                                                <label class="form-label">Position</label>
                                                <input type="text" class="form-control" name="teamMembers[<%= index %>][position]" value="<%= member.position %>" required>
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="form-label">Sort Order</label>
                                                <input type="number" class="form-control" name="teamMembers[<%= index %>][sortOrder]" value="<%= member.sortOrder || 0 %>">
                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label">Bio</label>
                                            <textarea class="form-control" name="teamMembers[<%= index %>][bio]" rows="2"><%= member.bio || '' %></textarea>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeTeamMember(this)">
                                            <i class="fa fa-trash me-2"></i>Remove
                                        </button>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                        <button type="button" class="btn btn-sm btn-success" onclick="addTeamMember()">
                            <i class="fa fa-plus me-2"></i>Add Team Member
                        </button>
                    </div>

                    <!-- Milestones Section -->
                    <div class="mb-4">
                        <h6 class="mb-3">Company Milestones</h6>
                        <div id="milestones-container">
                            <% if (aboutData.milestones && aboutData.milestones.length > 0) { %>
                                <% aboutData.milestones.forEach(function(milestone, index) { %>
                                    <div class="milestone-item border rounded p-3 mb-3">
                                        <div class="row">
                                            <div class="col-md-2 mb-2">
                                                <label class="form-label">Year</label>
                                                <input type="text" class="form-control" name="milestones[<%= index %>][year]" value="<%= milestone.year %>" required>
                                            </div>
                                            <div class="col-md-3 mb-2">
                                                <label class="form-label">Title</label>
                                                <input type="text" class="form-control" name="milestones[<%= index %>][title]" value="<%= milestone.title %>" required>
                                            </div>
                                            <div class="col-md-5 mb-2">
                                                <label class="form-label">Description</label>
                                                <input type="text" class="form-control" name="milestones[<%= index %>][description]" value="<%= milestone.description %>" required>
                                            </div>
                                            <div class="col-md-2 mb-2">
                                                <label class="form-label">Sort Order</label>
                                                <input type="number" class="form-control" name="milestones[<%= index %>][sortOrder]" value="<%= milestone.sortOrder || 0 %>">
                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label">Icon (Optional)</label>
                                            <input type="text" class="form-control" name="milestones[<%= index %>][icon]" value="<%= milestone.icon || '' %>" placeholder="fa-trophy">
                                        </div>
                                        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeMilestone(this)">
                                            <i class="fa fa-trash me-2"></i>Remove
                                        </button>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                        <button type="button" class="btn btn-sm btn-success" onclick="addMilestone()">
                            <i class="fa fa-plus me-2"></i>Add Milestone
                        </button>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-save me-2"></i>Update About
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
// Image preview functionality
document.getElementById('formFileMultiple')?.addEventListener('change', function(e) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    preview.style.display = 'flex';
    
    if (e.target.files.length > 0) {
        for (let i = 0; i < e.target.files.length; i++) {
            const file = e.target.files[i];
            const reader = new FileReader();
            
            reader.onload = function(e) {
                const imgContainer = document.createElement('div');
                imgContainer.style.position = 'relative';
                imgContainer.style.marginBottom = '10px';
                
                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.width = '100px';
                img.style.height = '100px';
                img.style.objectFit = 'cover';
                img.style.borderRadius = '5px';
                img.style.border = '1px solid #ddd';
                
                imgContainer.appendChild(img);
                preview.appendChild(imgContainer);
            }
            
            reader.readAsDataURL(file);
        }
    } else {
        preview.style.display = 'none';
    }
});

// Delete image function
function deleteImage(publicId, aboutId) {
    if (confirm('Are you sure you want to remove this image? This action cannot be undone.')) {
        fetch('/admin/about/images/delete/' + aboutId + '/' + publicId, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => {
            if (response.ok) {
                location.reload();
            } else {
                alert('Failed to delete image');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting image');
        });
    }
}

// Social Links Functions
function addSocialLink() {
    const container = document.getElementById('social-links-container');
    const index = container.children.length;
    const newLink = document.createElement('div');
    newLink.className = 'social-link-item border rounded p-3 mb-3';
    newLink.innerHTML = `
        <div class="row">
            <div class="col-md-3 mb-2">
                <label class="form-label">Platform</label>
                <select class="form-control" name="socialLinks[${index}][platform]" onchange="updateIcon(this)">
                    <option value="facebook">Facebook</option>
                    <option value="twitter">Twitter</option>
                    <option value="linkedin">LinkedIn</option>
                    <option value="instagram">Instagram</option>
                    <option value="youtube">YouTube</option>
                    <option value="github">GitHub</option>
                </select>
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">URL</label>
                <input type="url" class="form-control" name="socialLinks[${index}][url]" required>
            </div>
            <div class="col-md-3 mb-2">
                <label class="form-label">Icon</label>
                <input type="text" class="form-control" name="socialLinks[${index}][icon]" readonly>
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Active</label>
                <select class="form-control" name="socialLinks[${index}][isActive]">
                    <option value="true" selected>Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
        </div>
        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeSocialLink(this)">
            <i class="fa fa-trash me-2"></i>Remove
        </button>
    `;
    container.appendChild(newLink);
    updateIcon(newLink.querySelector('select'));
}

function removeSocialLink(button) {
    if (confirm('Are you sure you want to remove this social link?')) {
        button.closest('.social-link-item').remove();
    }
}

function updateIcon(select) {
    const platform = select.value;
    const iconMap = {
        facebook: 'fa-facebook',
        twitter: 'fa-twitter',
        linkedin: 'fa-linkedin',
        instagram: 'fa-instagram',
        youtube: 'fa-youtube',
        github: 'fa-github'
    };
    const iconInput = select.closest('.row').querySelector('input[name$="[icon]"]');
    if (iconInput) {
        iconInput.value = iconMap[platform] || 'fa-link';
    }
}

// Team Members Functions
function addTeamMember() {
    const container = document.getElementById('team-members-container');
    const index = container.children.length;
    const newMember = document.createElement('div');
    newMember.className = 'team-member-item border rounded p-3 mb-3';
    newMember.innerHTML = `
        <div class="row">
            <div class="col-md-4 mb-2">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" name="teamMembers[${index}][name]" required>
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">Position</label>
                <input type="text" class="form-control" name="teamMembers[${index}][position]" required>
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Sort Order</label>
                <input type="number" class="form-control" name="teamMembers[${index}][sortOrder]" value="0">
            </div>
        </div>
        <div class="mb-2">
            <label class="form-label">Bio</label>
            <textarea class="form-control" name="teamMembers[${index}][bio]" rows="2"></textarea>
        </div>
        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeTeamMember(this)">
            <i class="fa fa-trash me-2"></i>Remove
        </button>
    `;
    container.appendChild(newMember);
}

function removeTeamMember(button) {
    if (confirm('Are you sure you want to remove this team member?')) {
        button.closest('.team-member-item').remove();
    }
}

// Milestones Functions
function addMilestone() {
    const container = document.getElementById('milestones-container');
    const index = container.children.length;
    const newMilestone = document.createElement('div');
    newMilestone.className = 'milestone-item border rounded p-3 mb-3';
    newMilestone.innerHTML = `
        <div class="row">
            <div class="col-md-2 mb-2">
                <label class="form-label">Year</label>
                <input type="text" class="form-control" name="milestones[${index}][year]" required>
            </div>
            <div class="col-md-3 mb-2">
                <label class="form-label">Title</label>
                <input type="text" class="form-control" name="milestones[${index}][title]" required>
            </div>
            <div class="col-md-5 mb-2">
                <label class="form-label">Description</label>
                <input type="text" class="form-control" name="milestones[${index}][description]" required>
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Sort Order</label>
                <input type="number" class="form-control" name="milestones[${index}][sortOrder]" value="0">
            </div>
        </div>
        <div class="mb-2">
            <label class="form-label">Icon (Optional)</label>
            <input type="text" class="form-control" name="milestones[${index}][icon]" placeholder="fa-trophy">
        </div>
        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeMilestone(this)">
            <i class="fa fa-trash me-2"></i>Remove
        </button>
    `;
    container.appendChild(newMilestone);
}

function removeMilestone(button) {
    if (confirm('Are you sure you want to remove this milestone?')) {
        button.closest('.milestone-item').remove();
    }
}
</script>

<style>
.timeline-item {
    position: relative;
    padding-left: 30px;
    margin-bottom: 20px;
}
.timeline-item:before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #e9ecef;
}
</style>