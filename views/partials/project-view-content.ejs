<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-8">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0">Project Details</h5>
                    <a href="/admin/projects/list" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <div class="card">
                    <div class="card-body">
                        <h4><%= projectData.title %></h4>
                        <p><%= projectData.description %></p>
                        <hr>
                        <p><strong>Location:</strong> <%= projectData.location %></p>
                        <p><strong>Start Date:</strong> <%= new Date(projectData.startDate).toLocaleDateString() %></p>
                        <p><strong>End Date:</strong> <%= projectData.endDate ? new Date(projectData.endDate).toLocaleDateString() : 'Ongoing' %></p>
                        <p><strong>Status:</strong> 
                            <span class="badge bg-<%= projectData.status === 'completed' ? 'success' : 'primary' %>">
                                <%= projectData.status %>
                            </span>
                        </p>
                        
                        <% if (projectData.images && projectData.images.length > 0) { %>
                            <hr>
                            <p><strong>Images:</strong></p>
                            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                                <% projectData.images.forEach(function(image) { %>
                                    <img src="<%= image.url %>" alt="Project Image" 
                                         style="width: 150px; height: 150px; object-fit: cover; border-radius: 5px;">
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                </div>
                
                <div class="mt-3">
                    <a href="/admin/projects/edit/<%= projectData.id %>" class="btn btn-warning">
                        <i class="fa fa-edit me-2"></i>Edit
                    </a>
                    <button class="btn btn-danger" onclick="deleteProject(<%= projectData.id %>)">
                        <i class="fa fa-trash me-2"></i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function deleteProject(id) {
    if (confirm('Are you sure you want to delete this project?')) {
        window.location.href = '/admin/projects/delete/' + id;
    }
}
</script>