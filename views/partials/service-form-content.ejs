<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-8">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0"><%= isEdit ? 'Edit Service' : 'Create New Service' %></h5>
                    <a href="/admin/services" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <form action="<%= isEdit ? '/admin/services/update/' + serviceData.id : '/admin/services' %>" 
                      method="POST" 
                      enctype="multipart/form-data">
                    
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="title" value="<%= serviceData.title || '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Subtitle</label>
                        <input type="text" class="form-control" name="subtitle" value="<%= serviceData.subtitle || '' %>">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Short Description</label>
                        <textarea class="form-control" name="shortDescription" rows="3"><%= serviceData.shortDescription || '' %></textarea>
                        <small class="text-muted">Brief description for cards and previews</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Full Description</label>
                        <textarea class="form-control" name="description" rows="6"><%= serviceData.description || '' %></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Icon (Font Awesome)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa <%= serviceData.icon || 'fa-cog' %>"></i></span>
                                <input type="text" class="form-control" name="icon" value="<%= serviceData.icon || '' %>" placeholder="fa-cog">
                            </div>
                            <small class="text-muted">Enter Font Awesome icon class (e.g., fa-cog, fa-laptop, fa-mobile)</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Link (Optional)</label>
                            <input type="url" class="form-control" name="link" value="<%= serviceData.link || '' %>" placeholder="https://example.com/service">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-control" name="status">
                                <option value="active" <%= serviceData.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%= serviceData.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                                <option value="coming_soon" <%= serviceData.status === 'coming_soon' ? 'selected' : '' %>>Coming Soon</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Featured</label>
                            <select class="form-control" name="isFeatured">
                                <option value="true" <%= serviceData.isFeatured !== false ? 'selected' : '' %>>Featured</option>
                                <option value="false" <%= serviceData.isFeatured === false ? 'selected' : '' %>>Regular</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Sort Order</label>
                            <input type="number" class="form-control" name="sortOrder" value="<%= serviceData.sortOrder || 0 %>" min="0">
                            <small class="text-muted">Lower numbers appear first</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Features/Points</label>
                        <div id="features-container">
                            <% if (serviceData.features && serviceData.features.length > 0) { %>
                                <% serviceData.features.forEach(function(feature, index) { %>
                                    <div class="input-group mb-2 feature-item">
                                        <input type="text" class="form-control" name="features[]" value="<%= feature %>" placeholder="Enter feature">
                                        <button type="button" class="btn btn-danger" onclick="removeFeature(this)">
                                            <i class="fa fa-times"></i>
                                        </button>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="input-group mb-2 feature-item">
                                    <input type="text" class="form-control" name="features[]" placeholder="Enter feature">
                                    <button type="button" class="btn btn-danger" onclick="removeFeature(this)">
                                        <i class="fa fa-times"></i>
                                    </button>
                                </div>
                            <% } %>
                        </div>
                        <button type="button" class="btn btn-sm btn-success" onclick="addFeature()">
                            <i class="fa fa-plus me-2"></i>Add Feature
                        </button>
                        <small class="text-muted d-block mt-2">Add key features or points about this service</small>
                    </div>

                    <!-- Image Upload Section -->
                    <div class="mb-3">
                        <label for="formFileMultiple" class="form-label">Service Images</label>
                        <input class="form-control" type="file" name="images" id="formFileMultiple" multiple accept="image/*">
                        <small class="text-muted">You can select multiple images (JPG, PNG, GIF)</small>
                        
                        <!-- Image Preview Container -->
                        <div class="image-preview mt-3" id="imagePreview" style="display: flex; flex-wrap: wrap; gap: 10px;"></div>
                        
                        <!-- Existing Images (for edit mode) -->
                        <% if (isEdit && serviceData.images && serviceData.images.length > 0) { %>
                            <div class="existing-images mt-3">
                                <label class="form-label fw-bold mt-3">Existing Images</label>
                                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                                    <% serviceData.images.forEach(function(image) { %>
                                        <div class="image-item" style="position: relative; margin-bottom: 10px;">
                                            <img src="<%= image.url %>" alt="Service Image" 
                                                 style="width: 100px; height: 100px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;">
                                            <button type="button" class="btn btn-sm btn-danger" 
                                                    style="position: absolute; top: -8px; right: -8px; border-radius: 50%; width: 25px; height: 25px; padding: 0; display: flex; align-items: center; justify-content: center;"
                                                    onclick="removeImage('<%= encodeURIComponent(image.publicId) %>', '<%= serviceData.id %>')">
                                                <i class="fa fa-times" style="font-size: 12px;"></i>
                                            </button>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">
                        <i class="fa <%= isEdit ? 'fa-edit' : 'fa-plus' %> me-2"></i>
                        <%= isEdit ? 'Update' : 'Create' %> Service
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
// Add new feature input
function addFeature() {
    const container = document.getElementById('features-container');
    const newFeature = document.createElement('div');
    newFeature.className = 'input-group mb-2 feature-item';
    newFeature.innerHTML = `
        <input type="text" class="form-control" name="features[]" placeholder="Enter feature">
        <button type="button" class="btn btn-danger" onclick="removeFeature(this)">
            <i class="fa fa-times"></i>
        </button>
    `;
    container.appendChild(newFeature);
}

// Remove feature input
function removeFeature(button) {
    const featureItem = button.closest('.feature-item');
    if (featureItem) {
        featureItem.remove();
    }
}

// Image preview functionality
document.getElementById('formFileMultiple')?.addEventListener('change', function(e) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    preview.style.display = 'flex';
    
    if (e.target.files.length > 0) {
        for (let i = 0; i < e.target.files.length; i++) {
            const file = e.target.files[i];
            const reader = new FileReader();
            
            reader.onload = function(e) {
                const imgContainer = document.createElement('div');
                imgContainer.style.position = 'relative';
                imgContainer.style.marginBottom = '10px';
                
                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.width = '100px';
                img.style.height = '100px';
                img.style.objectFit = 'cover';
                img.style.borderRadius = '5px';
                img.style.border = '1px solid #ddd';
                
                imgContainer.appendChild(img);
                preview.appendChild(imgContainer);
            }
            
            reader.readAsDataURL(file);
        }
    } else {
        preview.style.display = 'none';
    }
});

// Delete image function
function removeImage(publicId, serviceId) {
    if (confirm('Are you sure you want to remove this image? This action cannot be undone.')) {
        fetch('/admin/services/images/' + serviceId + '/' + publicId, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => {
            if (response.ok) {
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-success alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="fa fa-check-circle me-2"></i>Image deleted successfully
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.bg-light').prepend(alertDiv);
                
                setTimeout(() => {
                    location.reload();
                }, 1000);
            } else {
                response.json().then(data => {
                    alert('Failed to delete image: ' + (data.error || 'Unknown error'));
                });
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting image: ' + error.message);
        });
    }
}
</script>