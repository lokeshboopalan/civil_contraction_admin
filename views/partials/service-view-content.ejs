<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-8">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0">Service Details</h5>
                    <a href="/admin/services" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <!-- Images Gallery -->
                <% if (serviceData.images && serviceData.images.length > 0) { %>
                    <div class="text-center mb-4">
                        <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                            <% serviceData.images.forEach(function(image) { %>
                                <img src="<%= image.url %>" alt="Service Image" 
                                     style="width: 200px; height: 150px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;">
                            <% }); %>
                        </div>
                    </div>
                    <hr>
                <% } %>
                
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-4">
                            <% if (serviceData.icon) { %>
                                <div class="me-3">
                                    <i class="fa <%= serviceData.icon %> fa-3x text-primary"></i>
                                </div>
                            <% } %>
                            <div>
                                <h4 class="mb-1"><%= serviceData.title %></h4>
                                <% if (serviceData.subtitle) { %>
                                    <h6 class="text-muted"><%= serviceData.subtitle %></h6>
                                <% } %>
                            </div>
                        </div>
                        
                        <% if (serviceData.shortDescription) { %>
                            <div class="alert alert-info">
                                <strong>Short Description:</strong><br>
                                <%= serviceData.shortDescription %>
                            </div>
                        <% } %>
                        
                        <% if (serviceData.description) { %>
                            <div class="mb-4">
                                <strong>Full Description:</strong>
                                <p class="mt-2"><%= serviceData.description %></p>
                            </div>
                        <% } %>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-4">
                                <p><strong>Status:</strong> 
                                    <span class="badge bg-<%= 
                                        serviceData.status === 'active' ? 'success' : 
                                        (serviceData.status === 'coming_soon' ? 'warning' : 'secondary') 
                                    %>">
                                        <%= serviceData.status.replace('_', ' ') %>
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <p><strong>Featured:</strong> 
                                    <span class="badge bg-<%= serviceData.isFeatured ? 'primary' : 'secondary' %>">
                                        <%= serviceData.isFeatured ? 'Yes' : 'No' %>
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-4">
                                <p><strong>Sort Order:</strong> <%= serviceData.sortOrder || 0 %></p>
                            </div>
                        </div>
                        
                        <% if (serviceData.link) { %>
                            <div class="row">
                                <div class="col-md-12">
                                    <p><strong>Link:</strong> <a href="<%= serviceData.link %>" target="_blank"><%= serviceData.link %></a></p>
                                </div>
                            </div>
                        <% } %>
                        
                        <% if (serviceData.features && serviceData.features.length > 0) { %>
                            <hr>
                            <p><strong>Features:</strong></p>
                            <ul>
                                <% serviceData.features.forEach(function(feature) { %>
                                    <li><%= feature %></li>
                                <% }); %>
                            </ul>
                        <% } %>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Created:</strong> <%= new Date(serviceData.createdAt).toLocaleString() %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Last Updated:</strong> <%= new Date(serviceData.updatedAt).toLocaleString() %></p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-3 text-center">
                    <a href="/admin/services/edit/<%= serviceData.id %>" class="btn btn-warning">
                        <i class="fa fa-edit me-2"></i>Edit
                    </a>
                    <form action="/admin/services/toggle-featured/<%= serviceData.id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-<%= serviceData.isFeatured ? 'secondary' : 'primary' %>">
                            <i class="fa fa-star me-2"></i>
                            <%= serviceData.isFeatured ? 'Remove Featured' : 'Make Featured' %>
                        </button>
                    </form>
                    <form action="/admin/services/delete/<%= serviceData.id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this service?')">
                            <i class="fa fa-trash me-2"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>