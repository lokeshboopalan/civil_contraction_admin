<div class="container-fluid pt-4 px-4">
    <div class="bg-light text-center rounded p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h6 class="mb-0">Sliders Management</h6>
            <a href="/admin/sliders/create" class="btn btn-primary">
                <i class="fa fa-plus me-2"></i>Add New Slider
            </a>
        </div>
        
        <!-- Success Message -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fa fa-check-circle me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <!-- Error Message -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <div class="table-responsive">
            <table class="table text-start align-middle table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Image</th>
                        <th scope="col">Title</th>
                        <th scope="col">Sub Title</th>
                        <th scope="col">Order</th>
                        <th scope="col">Status</th>
                        <th scope="col">Created</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (sliders && sliders.length > 0) { %>
                        <% for(var i = 0; i < sliders.length; i++) { 
                            var slider = sliders[i];
                        %>
                        <tr>
                            <td><%= slider.id %></td>
                            <td>
                                <% if (slider.images && slider.images.length > 0) { %>
                                    <img src="<%= slider.images[0].url %>" alt="Slider" 
                                         style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                <% } else { %>
                                    <span class="text-muted">No image</span>
                                <% } %>
                            </td>
                            <td><%= slider.title %></td>
                            <td><%= slider.subTitle || '-' %></td>
                            <td><%= slider.order %></td>
                            <td>
                                <span class="badge bg-<%= slider.isActive ? 'success' : 'secondary' %>">
                                    <%= slider.isActive ? 'Active' : 'Inactive' %>
                                </span>
                            </td>
                            <td><%= new Date(slider.createdAt).toLocaleDateString() %></td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a class="btn btn-sm btn-info" href="/admin/sliders/view/<%= slider.id %>" title="View">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <a class="btn btn-sm btn-warning" href="/admin/sliders/edit/<%= slider.id %>" title="Edit">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <form action="/admin/sliders/delete/<%= slider.id %>" method="POST" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete" 
                                                onclick="return confirm('Are you sure you want to delete this slider?')">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center py-4">
                                <i class="fa fa-image fa-3x text-muted mb-3"></i>
                                <p class="text-muted">No sliders found. Click "Add New Slider" to create one.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
// Auto-hide alerts after 5 seconds
setTimeout(function() {
    var alerts = document.querySelectorAll('.alert');
    alerts.forEach(function(alert) {
        var bsAlert = new bootstrap.Alert(alert);
        bsAlert.close();
    });
}, 5000);
</script>