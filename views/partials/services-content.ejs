<div class="container-fluid pt-4 px-4">
    <div class="bg-light text-center rounded p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h6 class="mb-0">Services Management</h6>
            <a href="/admin/services/create" class="btn btn-primary">
                <i class="fa fa-plus me-2"></i>Add New Service
            </a>
        </div>
        
        <!-- Success Message -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fa fa-check-circle me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <!-- Error Message -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <div class="table-responsive">
            <table class="table text-start align-middle table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Image</th>
                        <th scope="col">Icon</th>
                        <th scope="col">Title</th>
                        <th scope="col">Status</th>
                        <th scope="col">Featured</th>
                        <th scope="col">Sort</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (services && services.length > 0) { %>
                        <% for(var i = 0; i < services.length; i++) { 
                            var service = services[i];
                        %>
                        <tr>
                            <td><%= service.id %></td>
                            <td>
                                <% if (service.images && service.images.length > 0) { %>
                                    <img src="<%= service.images[0].url %>" alt="Service" 
                                         style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                <% } else { %>
                                    <span class="text-muted">No image</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (service.icon) { %>
                                    <i class="fa <%= service.icon %> fa-2x text-primary"></i>
                                <% } else { %>
                                    <span class="text-muted">-</span>
                                <% } %>
                            </td>
                            <td><%= service.title %></td>
                            <td>
                                <span class="badge bg-<%= 
                                    service.status === 'active' ? 'success' : 
                                    (service.status === 'coming_soon' ? 'warning' : 'secondary') 
                                %>">
                                    <%= service.status.replace('_', ' ') %>
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-<%= service.isFeatured ? 'primary' : 'secondary' %>">
                                    <%= service.isFeatured ? 'Featured' : 'Regular' %>
                                </span>
                            </td>
                            <td><%= service.sortOrder %></td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a class="btn btn-sm btn-info" href="/admin/services/view/<%= service.id %>" title="View">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <a class="btn btn-sm btn-warning" href="/admin/services/edit/<%= service.id %>" title="Edit">
                                        <i class="fa fa-edit"></i>
                                    </a>
                                    <form action="/admin/services/toggle-featured/<%= service.id %>" method="POST" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-<%= service.isFeatured ? 'secondary' : 'primary' %>" 
                                                title="<%= service.isFeatured ? 'Remove Featured' : 'Make Featured' %>">
                                            <i class="fa fa-star"></i>
                                        </button>
                                    </form>
                                    <form action="/admin/services/delete/<%= service.id %>" method="POST" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete" 
                                                onclick="return confirm('Are you sure you want to delete this service?')">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center py-4">
                                <i class="fa fa-cogs fa-3x text-muted mb-3"></i>
                                <p class="text-muted">No services found. Click "Add New Service" to create one.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
// Auto-hide alerts after 5 seconds
setTimeout(function() {
    var alerts = document.querySelectorAll('.alert');
    alerts.forEach(function(alert) {
        var bsAlert = new bootstrap.Alert(alert);
        bsAlert.close();
    });
}, 5000);
</script>