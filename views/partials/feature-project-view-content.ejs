<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-8">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h5 class="mb-0">Feature Project Details</h5>
                    <a href="/admin/feature-projects" class="btn btn-sm btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Back
                    </a>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <!-- Images Gallery -->
                <% if (projectData.images && projectData.images.length > 0) { %>
                    <div class="text-center mb-4">
                        <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                            <% projectData.images.forEach(function(image) { %>
                                <img src="<%= image.url %>" alt="Project Image" 
                                     style="width: 200px; height: 150px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;">
                            <% }); %>
                        </div>
                    </div>
                    <hr>
                <% } %>
                
                <div class="card">
                    <div class="card-body">
                        <h4 class="mb-3"><%= projectData.title %></h4>
                        
                        <div class="mb-4">
                            <%= projectData.description %>
                        </div>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Location:</strong> <%= projectData.location %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Status:</strong> 
                                    <span class="badge bg-<%= projectData.status === 'completed' ? 'success' : (projectData.status === 'ongoing' ? 'primary' : 'warning') %>">
                                        <%= projectData.status %>
                                    </span>
                                </p>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Start Date:</strong> <%= new Date(projectData.startDate).toLocaleDateString() %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>End Date:</strong> <%= projectData.endDate ? new Date(projectData.endDate).toLocaleDateString() : 'Ongoing' %></p>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Active:</strong> 
                                    <span class="badge bg-<%= projectData.isActive ? 'success' : 'secondary' %>">
                                        <%= projectData.isActive ? 'Yes' : 'No' %>
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Sort Order:</strong> <%= projectData.sortOrder || 0 %></p>
                            </div>
                        </div>
                        
                        <hr>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Created:</strong> <%= new Date(projectData.createdAt).toLocaleString() %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Last Updated:</strong> <%= new Date(projectData.updatedAt).toLocaleString() %></p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-3 text-center">
                    <a href="/admin/feature-projects/edit/<%= projectData.id %>" class="btn btn-warning">
                        <i class="fa fa-edit me-2"></i>Edit
                    </a>
                    <form action="/admin/feature-projects/toggle/<%= projectData.id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-<%= projectData.isActive ? 'secondary' : 'success' %>">
                            <i class="fa <%= projectData.isActive ? 'fa-ban' : 'fa-check' %> me-2"></i>
                            <%= projectData.isActive ? 'Deactivate' : 'Activate' %>
                        </button>
                    </form>
                    <form action="/admin/feature-projects/delete/<%= projectData.id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this feature project?')">
                            <i class="fa fa-trash me-2"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>